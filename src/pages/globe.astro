<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<meta name="description" content="A live globe for earthquakes, severe storms, wildfires, and volcanic activity using official free feeds." />
<meta name="theme-color" content="#020810" />
<meta property="og:title" content="koels.site — Globe" />
<meta property="og:description" content="A live 3D globe for earthquakes, severe storms, wildfires, and volcanic activity." />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://koels.site/globe" />
<meta property="og:image" content="https://koels.site/og.png" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content="https://koels.site/og.png" />
<link rel="canonical" href="https://koels.site/globe" />
<title>koels.site — Globe</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='15' fill='%23020810'/%3E%3Ccircle cx='16' cy='16' r='13' fill='none' stroke='%230078c8' stroke-width='0.8' opacity='0.4'/%3E%3Ccircle cx='16' cy='16' r='9' fill='none' stroke='%2340c8ff' stroke-width='0.8' opacity='0.5'/%3E%3Ccircle cx='16' cy='16' r='5' fill='none' stroke='%2300ffcc' stroke-width='0.8' opacity='0.8'/%3E%3Ccircle cx='16' cy='16' r='2' fill='%2340c8ff'/%3E%3Cpath d='M6 16h5M21 16h5M16 6v5M16 21v5' stroke='%2340c8ff' stroke-width='1.2' stroke-linecap='round' opacity='0.75'/%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://esm.sh" crossorigin>
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
<link rel="preconnect" href="https://earthquake.usgs.gov" crossorigin>
<link rel="preconnect" href="https://eonet.gsfc.nasa.gov" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style is:global>
@view-transition { navigation: auto; }
* { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #020810;
  --bg2: #070f1f;
  --panel: rgba(5, 8, 18, 0.82);
  --panel-strong: rgba(6, 10, 22, 0.94);
  --line: rgba(255, 255, 255, 0.08);
  --line-strong: rgba(64, 200, 255, 0.24);
  --text: #c8f0ff;
  --muted: rgba(200, 240, 255, 0.56);
  --dim: rgba(200, 240, 255, 0.28);
  --cyan: #40c8ff;
  --teal: #00ffcc;
  --red: #ff5d73;
  --orange: #ff9d4d;
  --yellow: #ffd75e;
  --mono: "JetBrains Mono", monospace;
  --sans: "Inter", system-ui, sans-serif;
  --safe-top: env(safe-area-inset-top, 0px);
  --safe-bottom: env(safe-area-inset-bottom, 0px);
}
html, body {
  width: 100%;
  min-height: 100%;
  background:
    radial-gradient(circle at 20% 20%, rgba(0, 120, 200, 0.22), transparent 28%),
    radial-gradient(circle at 80% 12%, rgba(0, 255, 204, 0.12), transparent 22%),
    radial-gradient(circle at 50% 80%, rgba(255, 93, 115, 0.08), transparent 26%),
    linear-gradient(180deg, #030812 0%, #020810 45%, #050a15 100%);
  color: var(--text);
  font-family: var(--sans);
  overflow: hidden;
  -webkit-font-smoothing: antialiased;
}
body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px);
  background-size: 26px 26px;
  mask-image: radial-gradient(circle at center, rgba(0,0,0,0.9), transparent 92%);
}
a { color: inherit; text-decoration: none; }
button, input { font: inherit; }
button {
  border: 0;
  background: none;
  color: inherit;
}

#app {
  position: fixed;
  inset: 0;
}

#globe-canvas {
  position: absolute;
  inset: 0;
}

.topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: calc(var(--safe-top) + 16px) 20px 0;
  pointer-events: none;
}

.brand,
.toolbar,
.hud,
.panel,
.footer-links,
.status-toast {
  pointer-events: auto;
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  padding: 10px 14px;
  border: 1px solid var(--line);
  background: rgba(4, 8, 18, 0.76);
  border-radius: 16px;
  -webkit-backdrop-filter: blur(18px);
  backdrop-filter: blur(18px);
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.34);
}

.brand-mark {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  background:
    radial-gradient(circle at 30% 30%, rgba(64, 200, 255, 0.9), rgba(64, 200, 255, 0.08) 60%, transparent 62%),
    radial-gradient(circle at 70% 70%, rgba(0, 255, 204, 0.48), transparent 48%);
  box-shadow: 0 0 26px rgba(64, 200, 255, 0.3);
}

.brand-mark svg { width: 20px; height: 20px; }
.brand-copy { display: flex; flex-direction: column; gap: 4px; }
.brand-kicker {
  font-family: var(--mono);
  font-size: 0.54rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--dim);
}
.brand-title {
  font-size: 0.86rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.toolbar {
  display: flex;
  align-items: center;
  gap: 10px;
}

.tool-btn,
.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 38px;
  padding: 0 14px;
  border-radius: 999px;
  border: 1px solid var(--line);
  background: rgba(4, 8, 18, 0.74);
  color: var(--muted);
  font-family: var(--mono);
  font-size: 0.6rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  cursor: pointer;
  transition: border-color 0.18s, background 0.18s, color 0.18s, transform 0.18s;
  -webkit-backdrop-filter: blur(18px);
  backdrop-filter: blur(18px);
}

.tool-btn:hover,
.chip:hover {
  color: var(--text);
  border-color: rgba(255, 255, 255, 0.18);
  transform: translateY(-1px);
}

.tool-btn svg {
  width: 13px;
  height: 13px;
  fill: currentColor;
}

.chip-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: currentColor;
  box-shadow: 0 0 12px currentColor;
}

.chip.active {
  color: var(--text);
  border-color: rgba(64, 200, 255, 0.38);
  background: rgba(0, 120, 200, 0.18);
}

.chip[data-filter="quakes"].active { color: var(--cyan); }
.chip[data-filter="storms"].active { color: var(--red); }
.chip[data-filter="wildfires"].active { color: var(--orange); }
.chip[data-filter="volcanoes"].active { color: var(--yellow); }

.hud {
  position: fixed;
  left: 20px;
  bottom: calc(var(--safe-bottom) + 22px);
  z-index: 15;
  display: grid;
  gap: 10px;
  width: min(360px, calc(100vw - 40px));
}

.hud-card,
.panel,
.footer-links,
.status-toast {
  border: 1px solid var(--line);
  background: var(--panel);
  -webkit-backdrop-filter: blur(18px);
  backdrop-filter: blur(18px);
  box-shadow: 0 16px 50px rgba(0, 0, 0, 0.32);
}

.hud-card {
  border-radius: 18px;
  padding: 16px 18px;
}

.hud-kicker,
.panel-kicker,
.list-kicker,
.stat-label {
  font-family: var(--mono);
  font-size: 0.54rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--dim);
}

.hud-title {
  margin-top: 8px;
  font-size: clamp(1.35rem, 2vw, 1.8rem);
  line-height: 1.08;
  letter-spacing: -0.02em;
  max-width: 12ch;
}

.hud-sub {
  margin-top: 12px;
  font-size: 0.82rem;
  line-height: 1.7;
  color: var(--muted);
  max-width: 34ch;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
}

.stat {
  min-width: 0;
  padding: 12px 12px 10px;
  border-radius: 14px;
  border: 1px solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.02);
}

.stat-value {
  margin-top: 8px;
  font-size: 1.32rem;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.03em;
}

.stat-meta {
  margin-top: 4px;
  font-size: 0.66rem;
  color: var(--muted);
}

.panel {
  position: fixed;
  top: calc(var(--safe-top) + 90px);
  right: 20px;
  bottom: calc(var(--safe-bottom) + 20px);
  z-index: 15;
  width: min(420px, calc(100vw - 40px));
  border-radius: 22px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.panel-head {
  padding: 18px 18px 14px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  background: linear-gradient(180deg, rgba(255,255,255,0.03), transparent);
}

.panel-title-row {
  margin-top: 10px;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.panel-title {
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.panel-updated {
  font-family: var(--mono);
  font-size: 0.56rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  white-space: nowrap;
}

.filter-row {
  margin-top: 14px;
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.feed {
  min-height: 0;
  overflow-y: auto;
  padding: 8px 10px 14px;
}

.feed::-webkit-scrollbar { width: 6px; }
.feed::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 999px;
}

.selected {
  margin: 0 8px 10px;
  padding: 16px;
  border-radius: 18px;
  border: 1px solid rgba(64, 200, 255, 0.18);
  background: rgba(0, 120, 200, 0.08);
}

.selected.empty {
  border-style: dashed;
  background: rgba(255, 255, 255, 0.02);
}

.selected-type {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: var(--muted);
  font-family: var(--mono);
  font-size: 0.56rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.selected-title {
  margin-top: 10px;
  font-size: 1rem;
  font-weight: 700;
  line-height: 1.35;
}

.selected-meta {
  margin-top: 10px;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.meta-pill {
  padding: 6px 10px;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.03);
  font-family: var(--mono);
  font-size: 0.56rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
}

.selected-copy {
  margin-top: 12px;
  font-size: 0.78rem;
  line-height: 1.7;
  color: var(--muted);
}

.selected-link {
  margin-top: 14px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 14px;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.03);
  font-family: var(--mono);
  font-size: 0.58rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text);
}

.list-head {
  padding: 6px 8px 10px;
}

.event-list {
  display: grid;
  gap: 8px;
}

.event-btn {
  width: 100%;
  text-align: left;
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.02);
  padding: 13px 14px;
  cursor: pointer;
  transition: border-color 0.16s, background 0.16s, transform 0.16s;
}

.event-btn:hover,
.event-btn:focus-visible {
  outline: none;
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.16);
  transform: translateY(-1px);
}

.event-btn.active {
  border-color: rgba(64, 200, 255, 0.28);
  background: rgba(0, 120, 200, 0.12);
}

.event-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.event-type {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
}

.event-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 0 14px currentColor;
}

.event-label {
  font-family: var(--mono);
  font-size: 0.55rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
}

.event-time {
  font-family: var(--mono);
  font-size: 0.52rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--dim);
  white-space: nowrap;
}

.event-title {
  margin-top: 10px;
  font-size: 0.84rem;
  line-height: 1.45;
  color: var(--text);
}

.event-sub {
  margin-top: 7px;
  font-size: 0.68rem;
  line-height: 1.55;
  color: var(--muted);
}

.footer-links {
  position: fixed;
  right: 20px;
  bottom: calc(var(--safe-bottom) + 20px);
  z-index: 15;
  display: inline-flex;
  align-items: center;
  gap: 18px;
  padding: 12px 16px;
  border-radius: 999px;
  font-family: var(--mono);
  font-size: 0.58rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
}

.footer-links a:hover { color: var(--text); }

.status-toast {
  position: fixed;
  top: calc(var(--safe-top) + 82px);
  left: 50%;
  transform: translateX(-50%);
  z-index: 25;
  padding: 10px 14px;
  border-radius: 999px;
  font-family: var(--mono);
  font-size: 0.56rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  opacity: 0;
  transition: opacity 0.2s;
  pointer-events: none;
}

.status-toast.show { opacity: 1; }

.loading-cover {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: grid;
  place-items: center;
  background: linear-gradient(180deg, rgba(2,8,16,0.94), rgba(2,8,16,0.82));
  transition: opacity 0.35s, visibility 0.35s;
}

.loading-cover.hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

.loading-box {
  display: grid;
  gap: 14px;
  justify-items: center;
}

.loading-ring {
  width: 78px;
  height: 78px;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.08);
  position: relative;
}

.loading-ring::before,
.loading-ring::after {
  content: "";
  position: absolute;
  inset: 10px;
  border-radius: 50%;
  border: 1px solid rgba(64, 200, 255, 0.18);
}

.loading-ring::after {
  inset: 0;
  border-top-color: var(--teal);
  border-right-color: var(--cyan);
  border-bottom-color: transparent;
  border-left-color: transparent;
  animation: spin 1.1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-family: var(--mono);
  font-size: 0.64rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--muted);
}

.screen-reader {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

@media (max-width: 1100px) {
  .panel {
    width: min(390px, calc(100vw - 28px));
    right: 14px;
    top: calc(var(--safe-top) + 84px);
    bottom: 14px;
  }
  .hud {
    left: 14px;
    bottom: 14px;
    width: min(320px, calc(100vw - 28px));
  }
  .footer-links { right: 14px; bottom: 14px; }
  .topbar { padding-left: 14px; padding-right: 14px; }
}

@media (max-width: 860px) {
  body { overflow: auto; }
  #app {
    position: relative;
    min-height: 100svh;
  }
  #globe-canvas {
    position: fixed;
    inset: 0;
  }
  .topbar {
    flex-direction: column;
    align-items: stretch;
    gap: 10px;
  }
  .toolbar {
    justify-content: space-between;
    flex-wrap: wrap;
  }
  .hud {
    left: 12px;
    right: 12px;
    width: auto;
    bottom: 256px;
  }
  .stats-row { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .panel {
    top: auto;
    left: 12px;
    right: 12px;
    bottom: 12px;
    width: auto;
    height: min(46svh, 420px);
  }
  .footer-links {
    display: none;
  }
}

@media (max-width: 640px) {
  .brand {
    padding: 10px 12px;
    border-radius: 14px;
  }
  .brand-title { font-size: 0.76rem; }
  .tool-btn, .chip {
    min-height: 34px;
    padding: 0 12px;
    font-size: 0.54rem;
  }
  .hud {
    bottom: 250px;
    gap: 8px;
  }
  .hud-card {
    padding: 14px;
    border-radius: 16px;
  }
  .hud-title {
    font-size: 1.2rem;
    max-width: none;
  }
  .hud-sub { font-size: 0.74rem; }
  .stats-row {
    grid-template-columns: 1fr;
  }
  .panel {
    height: min(50svh, 430px);
    border-radius: 18px;
  }
  .selected-title { font-size: 0.92rem; }
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}
</style>
</head>
<body>
<noscript>
  <div style="position:fixed;inset:0;display:grid;place-items:center;background:#020810;color:#c8f0ff;font-family:Inter,system-ui,sans-serif;padding:24px;text-align:center;z-index:9999">
    <div>
      <p style="font-size:1.1rem;font-weight:700;margin-bottom:8px">JavaScript Required</p>
      <p style="font-size:0.84rem;opacity:0.7;line-height:1.7">The globe needs JavaScript to render live data and the 3D scene.</p>
    </div>
  </div>
</noscript>

<div id="app">
  <canvas id="globe-canvas"></canvas>

  <div class="topbar">
    <a class="brand" href="/">
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="rgba(200,240,255,0.9)" stroke-width="1.5">
          <circle cx="12" cy="12" r="7.5"></circle>
          <path d="M4.5 12h15M12 4.5c2.2 2.3 3.3 4.8 3.3 7.5S14.2 17.2 12 19.5M12 4.5c-2.2 2.3-3.3 4.8-3.3 7.5S9.8 17.2 12 19.5"></path>
        </svg>
      </span>
      <span class="brand-copy">
        <span class="brand-kicker">koels.site / live globe</span>
        <span class="brand-title">Earth Signals</span>
      </span>
    </a>

    <div class="toolbar">
      <button class="tool-btn" id="recenter-btn" type="button" aria-label="Recenter the globe">
        <svg viewBox="0 0 24 24"><path d="M11 2h2v4h-2zM11 18h2v4h-2zM2 11h4v2H2zM18 11h4v2h-4zM12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm0 2a3 3 0 1 1 0 6 3 3 0 0 1 0-6z"/></svg>
        Recenter
      </button>
      <button class="tool-btn" id="autospin-btn" type="button" aria-pressed="true">
        <svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 1 0 9.6 12.8h-2.1A8 8 0 1 1 12 4c2.2 0 4.2.9 5.7 2.4L14 10h8V2l-2.9 2.9A9.9 9.9 0 0 0 12 2z"/></svg>
        Auto spin
      </button>
    </div>
  </div>

  <div class="hud">
    <div class="hud-card">
      <div class="hud-kicker">Global conditions / official feeds</div>
      <h1 class="hud-title">Weather and earth events, all at once.</h1>
      <p class="hud-sub">USGS earthquakes and NASA EONET open events rendered on a live 3D globe with no paid APIs, no fake markers, and no static mock data.</p>
    </div>

    <div class="hud-card">
      <div class="stats-row">
        <div class="stat">
          <div class="stat-label">Quakes / 24h</div>
          <div class="stat-value" id="stat-quakes">--</div>
          <div class="stat-meta" id="stat-strong">-- strong</div>
        </div>
        <div class="stat">
          <div class="stat-label">Live storms</div>
          <div class="stat-value" id="stat-storms">--</div>
          <div class="stat-meta">Severe weather systems</div>
        </div>
        <div class="stat">
          <div class="stat-label">Open events</div>
          <div class="stat-value" id="stat-events">--</div>
          <div class="stat-meta" id="stat-fires">-- fires tracked</div>
        </div>
      </div>
    </div>
  </div>

  <aside class="panel" aria-label="Live event feed">
    <div class="panel-head">
      <div class="panel-kicker">Interactive feed</div>
      <div class="panel-title-row">
        <div class="panel-title">Live event stream</div>
        <div class="panel-updated" id="panel-updated">Syncing…</div>
      </div>
      <div class="filter-row" id="filter-row">
        <button class="chip active" data-filter="quakes" type="button"><span class="chip-dot"></span>Quakes</button>
        <button class="chip active" data-filter="storms" type="button"><span class="chip-dot"></span>Storms</button>
        <button class="chip active" data-filter="wildfires" type="button"><span class="chip-dot"></span>Wildfires</button>
        <button class="chip active" data-filter="volcanoes" type="button"><span class="chip-dot"></span>Volcanoes</button>
      </div>
    </div>

    <div class="feed">
      <section class="selected empty" id="selected-card" aria-live="polite">
        <div class="selected-type"><span class="chip-dot" style="background:var(--cyan)"></span>Select a marker or feed item</div>
        <div class="selected-title">Nothing focused yet.</div>
        <div class="selected-copy">Drag the globe, tap a live marker, or use the feed below to swing the camera onto an event.</div>
      </section>

      <div class="list-head">
        <div class="list-kicker">Highest signal right now</div>
      </div>
      <div class="event-list" id="event-list"></div>
      <div class="screen-reader" id="a11y-status" aria-live="polite"></div>
    </div>
  </aside>

  <div class="footer-links">
    <a href="/">Home</a>
    <a href="/radar">Radar</a>
    <a href="/status">Status</a>
    <a href="/links">Links</a>
  </div>

  <div class="status-toast" id="status-toast">Syncing feeds…</div>

  <div class="loading-cover" id="loading-cover">
    <div class="loading-box">
      <div class="loading-ring"></div>
      <div class="loading-text">Locking on to live feeds</div>
    </div>
  </div>
</div>

<script type="module" is:inline>
import * as THREE from 'https://esm.sh/three@0.179.1';
import { OrbitControls } from 'https://esm.sh/three@0.179.1/examples/jsm/controls/OrbitControls.js';
import { mesh } from 'https://esm.sh/topojson-client@3.1.0';

const canvas = document.getElementById('globe-canvas');
const loadingCover = document.getElementById('loading-cover');
const statusToast = document.getElementById('status-toast');
const a11yStatus = document.getElementById('a11y-status');
const eventList = document.getElementById('event-list');
const selectedCard = document.getElementById('selected-card');
const panelUpdated = document.getElementById('panel-updated');
const statQuakes = document.getElementById('stat-quakes');
const statStrong = document.getElementById('stat-strong');
const statStorms = document.getElementById('stat-storms');
const statEvents = document.getElementById('stat-events');
const statFires = document.getElementById('stat-fires');
const filterButtons = [...document.querySelectorAll('.chip[data-filter]')];
const recenterBtn = document.getElementById('recenter-btn');
const autospinBtn = document.getElementById('autospin-btn');

const scene = new THREE.Scene();
scene.fog = new THREE.FogExp2(0x020810, 0.028);

const camera = new THREE.PerspectiveCamera(42, window.innerWidth / window.innerHeight, 0.1, 200);
camera.position.set(0, 0, 11.5);

const renderer = new THREE.WebGLRenderer({
  canvas,
  antialias: true,
  alpha: true,
  powerPreference: 'high-performance'
});
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.8));
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.outputColorSpace = THREE.SRGBColorSpace;

const globeGroup = new THREE.Group();
scene.add(globeGroup);

const controls = new OrbitControls(camera, renderer.domElement);
controls.enablePan = false;
controls.enableDamping = true;
controls.dampingFactor = 0.06;
controls.rotateSpeed = 0.6;
controls.minDistance = 7.2;
controls.maxDistance = 20;
controls.target.set(0, 0, 0);
let userInteracting = false;
controls.addEventListener('start', () => { userInteracting = true; });
controls.addEventListener('end', () => { userInteracting = false; });

const ambient = new THREE.AmbientLight(0xaed7ff, 0.85);
scene.add(ambient);

const keyLight = new THREE.DirectionalLight(0x8fd8ff, 1.7);
keyLight.position.set(8, 6, 10);
scene.add(keyLight);

const rimLight = new THREE.DirectionalLight(0x00ffcc, 1.1);
rimLight.position.set(-10, -4, -6);
scene.add(rimLight);

const earthRadius = 3.15;
const markerRadius = 3.28;
const globeMaterial = new THREE.MeshPhongMaterial({
  color: 0x071223,
  emissive: 0x061426,
  emissiveIntensity: 0.9,
  shininess: 28,
  specular: 0x0f2740,
  transparent: true,
  opacity: 0.98
});
const earth = new THREE.Mesh(new THREE.SphereGeometry(earthRadius, 96, 96), globeMaterial);
globeGroup.add(earth);

const halo = new THREE.Mesh(
  new THREE.SphereGeometry(earthRadius * 1.075, 96, 96),
  new THREE.MeshBasicMaterial({
    color: 0x40c8ff,
    transparent: true,
    opacity: 0.065,
    side: THREE.BackSide
  })
);
globeGroup.add(halo);

const atmosphere = new THREE.Mesh(
  new THREE.SphereGeometry(earthRadius * 1.13, 96, 96),
  new THREE.ShaderMaterial({
    uniforms: {
      glowColor: { value: new THREE.Color(0x42d0ff) },
      viewVector: { value: camera.position }
    },
    vertexShader: `
      uniform vec3 viewVector;
      varying float intensity;
      void main() {
        vec3 worldNormal = normalize(normalMatrix * normal);
        vec3 viewDir = normalize((modelViewMatrix * vec4(position, 1.0)).xyz);
        intensity = pow(0.72 - dot(worldNormal, viewDir), 2.6);
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `,
    fragmentShader: `
      uniform vec3 glowColor;
      varying float intensity;
      void main() {
        gl_FragColor = vec4(glowColor, intensity * 0.46);
      }
    `,
    blending: THREE.AdditiveBlending,
    side: THREE.BackSide,
    transparent: true,
    depthWrite: false
  })
);
globeGroup.add(atmosphere);

function makeStarField() {
  const count = 2600;
  const positions = new Float32Array(count * 3);
  for (let i = 0; i < count; i++) {
    const radius = THREE.MathUtils.randFloat(28, 58);
    const theta = THREE.MathUtils.randFloat(0, Math.PI * 2);
    const phi = Math.acos(THREE.MathUtils.randFloatSpread(2));
    const x = radius * Math.sin(phi) * Math.cos(theta);
    const y = radius * Math.cos(phi);
    const z = radius * Math.sin(phi) * Math.sin(theta);
    positions[i * 3] = x;
    positions[i * 3 + 1] = y;
    positions[i * 3 + 2] = z;
  }
  const geom = new THREE.BufferGeometry();
  geom.setAttribute('position', new THREE.BufferAttribute(positions, 3));
  const mat = new THREE.PointsMaterial({
    color: 0xd7efff,
    size: 0.08,
    sizeAttenuation: true,
    transparent: true,
    opacity: 0.9
  });
  return new THREE.Points(geom, mat);
}

scene.add(makeStarField());

function makeGrid() {
  const material = new THREE.LineBasicMaterial({
    color: 0x2d6688,
    transparent: true,
    opacity: 0.34
  });

  for (let lat = -60; lat <= 60; lat += 30) {
    const pts = [];
    for (let lon = -180; lon <= 180; lon += 3) pts.push(latLonToVector3(lat, lon, earthRadius * 1.002));
    const geom = new THREE.BufferGeometry().setFromPoints(pts);
    globeGroup.add(new THREE.LineLoop(geom, material));
  }

  for (let lon = 0; lon < 180; lon += 30) {
    const pts = [];
    for (let lat = -90; lat <= 90; lat += 2) pts.push(latLonToVector3(lat, lon, earthRadius * 1.002));
    const geom = new THREE.BufferGeometry().setFromPoints(pts);
    globeGroup.add(new THREE.Line(geom, material));

    const ptsMirror = [];
    for (let lat = -90; lat <= 90; lat += 2) ptsMirror.push(latLonToVector3(lat, -lon, earthRadius * 1.002));
    const geomMirror = new THREE.BufferGeometry().setFromPoints(ptsMirror);
    globeGroup.add(new THREE.Line(geomMirror, material));
  }
}

makeGrid();

function latLonToVector3(lat, lon, radius) {
  const phi = (90 - lat) * Math.PI / 180;
  const theta = (lon + 180) * Math.PI / 180;
  const x = -(radius * Math.sin(phi) * Math.cos(theta));
  const z = radius * Math.sin(phi) * Math.sin(theta);
  const y = radius * Math.cos(phi);
  return new THREE.Vector3(x, y, z);
}

function projectGeometryCoordinates(coords, radius, out = []) {
  if (!Array.isArray(coords)) return out;
  if (typeof coords[0] === 'number' && typeof coords[1] === 'number') {
    const lon = coords[0];
    const lat = coords[1];
    out.push(latLonToVector3(lat, lon, radius));
    return out;
  }
  coords.forEach(part => projectGeometryCoordinates(part, radius, out));
  return out;
}

async function addLandOutlines() {
  const topo = await fetch('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json').then(r => r.json());
  const linework = mesh(topo, topo.objects.countries, (a, b) => a !== b);
  const material = new THREE.LineBasicMaterial({
    color: 0x6fd6ff,
    transparent: true,
    opacity: 0.38
  });
  const group = new THREE.Group();

  (linework.coordinates || []).forEach(line => {
    const points = projectGeometryCoordinates(line, earthRadius * 1.01, []);
    if (points.length < 2) return;
    const geometry = new THREE.BufferGeometry().setFromPoints(points);
    group.add(new THREE.Line(geometry, material));
  });
  globeGroup.add(group);
}

const markerGroup = new THREE.Group();
globeGroup.add(markerGroup);

const categoryStyles = {
  quakes: { color: '#40c8ff', glow: 0x40c8ff },
  storms: { color: '#ff5d73', glow: 0xff5d73 },
  wildfires: { color: '#ff9d4d', glow: 0xff9d4d },
  volcanoes: { color: '#ffd75e', glow: 0xffd75e }
};

const activeFilters = new Set(['quakes', 'storms', 'wildfires', 'volcanoes']);
let events = [];
let markerEntries = [];
let selectedId = null;
let autoSpin = true;
let focusVector = null;
let focusDistance = 10.4;
let refreshTimer = null;

function showStatus(text) {
  statusToast.textContent = text;
  statusToast.classList.add('show');
  clearTimeout(showStatus._timer);
  showStatus._timer = setTimeout(() => statusToast.classList.remove('show'), 1800);
}

function formatAgo(isoLike) {
  const time = new Date(isoLike).getTime();
  if (!Number.isFinite(time)) return 'Unknown';
  const diffMin = Math.max(0, Math.round((Date.now() - time) / 60000));
  if (diffMin < 60) return `${diffMin}m ago`;
  if (diffMin < 1440) return `${Math.round(diffMin / 60)}h ago`;
  return `${Math.round(diffMin / 1440)}d ago`;
}

function formatUpdated(date) {
  return new Intl.DateTimeFormat('en-US', {
    hour: 'numeric',
    minute: '2-digit'
  }).format(date);
}

function eventTypeLabel(kind) {
  if (kind === 'quakes') return 'Earthquake';
  if (kind === 'storms') return 'Severe storm';
  if (kind === 'wildfires') return 'Wildfire';
  if (kind === 'volcanoes') return 'Volcano';
  return 'Event';
}

function normalizeEonetCategory(categories = []) {
  const ids = categories.map(c => (c.id || '').toLowerCase());
  if (ids.includes('severestorms')) return 'storms';
  if (ids.includes('wildfires')) return 'wildfires';
  if (ids.includes('volcanoes')) return 'volcanoes';
  return null;
}

function quakeIntensity(mag) {
  if (mag >= 6) return 'Major';
  if (mag >= 5) return 'Strong';
  if (mag >= 4) return 'Moderate';
  return 'Light';
}

function categorySummary(event) {
  if (event.kind === 'quakes') {
    return `${quakeIntensity(event.magnitude)} quake · M${event.magnitude.toFixed(1)}`;
  }
  if (event.kind === 'storms') return 'Open severe storm event';
  if (event.kind === 'wildfires') return event.magnitudeText || 'Active wildfire';
  if (event.kind === 'volcanoes') return event.magnitudeText || 'Volcanic activity';
  return event.kind;
}

function scoreEvent(event) {
  if (event.kind === 'quakes') return (event.magnitude || 0) * 140 + Math.max(0, 2000 - event.ageMinutes);
  if (event.kind === 'storms') return 880 + Math.max(0, 1500 - event.ageMinutes);
  if (event.kind === 'wildfires') {
    const areaWeight = Math.min(320, Math.log10((Number(event.magnitudeValue) || 0) + 1) * 95);
    return 260 + areaWeight + Math.max(0, 720 - event.ageMinutes);
  }
  if (event.kind === 'volcanoes') return 560 + Math.max(0, 1200 - event.ageMinutes);
  return 0;
}

async function fetchQuakes() {
  const data = await fetch('https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.geojson').then(r => r.json());
  return (data.features || [])
    .filter(feature => Array.isArray(feature.geometry?.coordinates))
    .map(feature => {
      const [lon, lat, depth] = feature.geometry.coordinates;
      const props = feature.properties || {};
      const timestamp = props.time || Date.now();
      return {
        id: `quake-${feature.id}`,
        kind: 'quakes',
        title: props.title || props.place || 'Earthquake',
        place: props.place || 'Unknown region',
        lat,
        lon,
        depth: typeof depth === 'number' ? depth : null,
        time: new Date(timestamp).toISOString(),
        ageMinutes: Math.max(0, Math.round((Date.now() - timestamp) / 60000)),
        magnitude: typeof props.mag === 'number' ? props.mag : 0,
        url: props.url || 'https://earthquake.usgs.gov/',
        source: 'USGS',
        description: props.place || 'Recent seismic activity',
        markerScale: THREE.MathUtils.clamp(0.16 + ((props.mag || 0) * 0.055), 0.2, 0.58),
        magnitudeText: `Depth ${depth ? Math.round(depth) : 0} km`
      };
    });
}

async function fetchEonetEvents() {
  const data = await fetch('https://eonet.gsfc.nasa.gov/api/v3/events?status=open&limit=80').then(r => r.json());
  return (data.events || [])
    .map(event => {
      const kind = normalizeEonetCategory(event.categories);
      if (!kind) return null;
      const geometry = [...(event.geometry || [])].reverse().find(item => item.type === 'Point' && Array.isArray(item.coordinates));
      if (!geometry) return null;
      const [lon, lat] = geometry.coordinates;
      const magnitudeValue = geometry.magnitudeValue;
      const magnitudeUnit = geometry.magnitudeUnit;
      const time = geometry.date || event.closed || new Date().toISOString();
      return {
        id: event.id,
        kind,
        title: event.title || 'Open natural event',
        place: event.description || event.title || 'Open natural event',
        lat,
        lon,
        time,
        ageMinutes: Math.max(0, Math.round((Date.now() - new Date(time).getTime()) / 60000)),
        magnitudeValue,
        magnitudeText: Number.isFinite(magnitudeValue) ? `${Math.round(magnitudeValue).toLocaleString()} ${magnitudeUnit || ''}`.trim() : '',
        url: event.sources?.[0]?.url || event.link || 'https://eonet.gsfc.nasa.gov/',
        source: `NASA EONET${event.sources?.[0]?.id ? ` / ${event.sources[0].id}` : ''}`,
        description: event.description || `Open ${eventTypeLabel(kind).toLowerCase()} from NASA EONET`,
        markerScale: kind === 'storms' ? 0.42 : kind === 'wildfires' ? 0.3 : 0.26
      };
    })
    .filter(Boolean);
}

function makeMarkerTexture(colorHex) {
  const size = 128;
  const canvasEl = document.createElement('canvas');
  canvasEl.width = size;
  canvasEl.height = size;
  const ctx = canvasEl.getContext('2d');
  const center = size / 2;
  const gradient = ctx.createRadialGradient(center, center, 6, center, center, center);
  gradient.addColorStop(0, 'rgba(255,255,255,1)');
  gradient.addColorStop(0.15, colorHex);
  gradient.addColorStop(0.45, colorHex + 'dd');
  gradient.addColorStop(1, 'rgba(0,0,0,0)');
  ctx.fillStyle = gradient;
  ctx.fillRect(0, 0, size, size);
  const texture = new THREE.CanvasTexture(canvasEl);
  texture.colorSpace = THREE.SRGBColorSpace;
  return texture;
}

const markerTextures = Object.fromEntries(
  Object.entries(categoryStyles).map(([key, value]) => [key, makeMarkerTexture(value.color)])
);

function clearMarkers() {
  markerEntries.forEach(entry => {
    markerGroup.remove(entry.sprite);
    entry.sprite.material.dispose?.();
  });
  markerEntries = [];
}

function rebuildMarkers() {
  clearMarkers();
  events.forEach(event => {
    const material = new THREE.SpriteMaterial({
      map: markerTextures[event.kind],
      transparent: true,
      depthWrite: false,
      opacity: activeFilters.has(event.kind) ? 1 : 0.14
    });
    const sprite = new THREE.Sprite(material);
    const pos = latLonToVector3(event.lat, event.lon, markerRadius);
    sprite.position.copy(pos);
    const scale = event.markerScale || 1;
    sprite.scale.setScalar(scale);
    sprite.userData.eventId = event.id;
    markerGroup.add(sprite);
    markerEntries.push({ event, sprite, baseScale: scale });
  });
}

function updateStats() {
  const quakes = events.filter(event => event.kind === 'quakes');
  const strongQuakes = quakes.filter(event => event.magnitude >= 4.5);
  const storms = events.filter(event => event.kind === 'storms');
  const wildfires = events.filter(event => event.kind === 'wildfires');

  statQuakes.textContent = quakes.length.toString();
  statStrong.textContent = `${strongQuakes.length} at M4.5+`;
  statStorms.textContent = storms.length.toString();
  statEvents.textContent = events.length.toString();
  statFires.textContent = `${wildfires.length} wildfires`;
}

function eventColor(kind) {
  return categoryStyles[kind]?.color || '#40c8ff';
}

function setSelectedCard(event) {
  if (!event) {
    selectedCard.className = 'selected empty';
    selectedCard.innerHTML = `
      <div class="selected-type"><span class="chip-dot" style="background:var(--cyan)"></span>Select a marker or feed item</div>
      <div class="selected-title">Nothing focused yet.</div>
      <div class="selected-copy">Drag the globe, tap a live marker, or use the feed below to swing the camera onto an event.</div>
    `;
    return;
  }

  selectedCard.className = 'selected';
  selectedCard.innerHTML = `
    <div class="selected-type"><span class="chip-dot" style="background:${eventColor(event.kind)}"></span>${eventTypeLabel(event.kind)}</div>
    <div class="selected-title">${escapeHtml(event.title)}</div>
    <div class="selected-meta">
      <span class="meta-pill">${escapeHtml(categorySummary(event))}</span>
      <span class="meta-pill">${escapeHtml(formatAgo(event.time))}</span>
      <span class="meta-pill">${escapeHtml(event.source)}</span>
    </div>
    <div class="selected-copy">${escapeHtml(event.place || event.description || 'Open event')}</div>
    <a class="selected-link" href="${escapeAttr(event.url)}" target="_blank" rel="noopener">Open source event ↗</a>
  `;
}

function renderEventList() {
  const visibleEvents = events
    .filter(event => activeFilters.has(event.kind))
    .sort((a, b) => scoreEvent(b) - scoreEvent(a))
    .slice(0, 14);

  eventList.innerHTML = '';
  visibleEvents.forEach(event => {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = `event-btn${event.id === selectedId ? ' active' : ''}`;
    btn.dataset.eventId = event.id;
    btn.innerHTML = `
      <div class="event-top">
        <div class="event-type">
          <span class="event-dot" style="color:${eventColor(event.kind)};background:${eventColor(event.kind)}"></span>
          <span class="event-label">${escapeHtml(eventTypeLabel(event.kind))}</span>
        </div>
        <span class="event-time">${escapeHtml(formatAgo(event.time))}</span>
      </div>
      <div class="event-title">${escapeHtml(event.title)}</div>
      <div class="event-sub">${escapeHtml(categorySummary(event))} · ${escapeHtml(event.place || 'Live event')}</div>
    `;
    btn.addEventListener('click', () => focusEvent(event.id));
    eventList.appendChild(btn);
  });

  if (!visibleEvents.length) {
    eventList.innerHTML = '<div class="event-sub" style="padding:8px 8px 20px;color:rgba(200,240,255,0.42)">All visible layers are off. Re-enable a feed to populate the globe.</div>';
  }
}

function escapeHtml(value) {
  return String(value ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function escapeAttr(value) {
  return escapeHtml(value);
}

function updateMarkerVisibility() {
  markerEntries.forEach(entry => {
    const visible = activeFilters.has(entry.event.kind);
    entry.sprite.material.opacity = visible ? 1 : 0.14;
    entry.sprite.visible = true;
  });
  renderEventList();
}

function focusEvent(id) {
  const event = events.find(item => item.id === id);
  if (!event) return;
  selectedId = id;
  const vector = latLonToVector3(event.lat, event.lon, focusDistance).normalize().multiplyScalar(focusDistance);
  focusVector = vector;
  autoSpin = false;
  autospinBtn.setAttribute('aria-pressed', 'false');
  autospinBtn.textContent = 'Auto spin';
  autospinBtn.insertAdjacentHTML('afterbegin', '<svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 1 0 9.6 12.8h-2.1A8 8 0 1 1 12 4c2.2 0 4.2.9 5.7 2.4L14 10h8V2l-2.9 2.9A9.9 9.9 0 0 0 12 2z"/></svg>');
  setSelectedCard(event);
  renderEventList();
  a11yStatus.textContent = `${eventTypeLabel(event.kind)} selected: ${event.title}`;
  showStatus(`${eventTypeLabel(event.kind)} locked`);
}

function resetCamera() {
  focusVector = new THREE.Vector3(0, 0, focusDistance);
  showStatus('View recentered');
}

function setAutospinState(on) {
  autoSpin = on;
  autospinBtn.innerHTML = '<svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 1 0 9.6 12.8h-2.1A8 8 0 1 1 12 4c2.2 0 4.2.9 5.7 2.4L14 10h8V2l-2.9 2.9A9.9 9.9 0 0 0 12 2z"/></svg>' + (on ? 'Auto spin on' : 'Auto spin');
  autospinBtn.setAttribute('aria-pressed', on ? 'true' : 'false');
}

filterButtons.forEach(button => {
  button.addEventListener('click', () => {
    const kind = button.dataset.filter;
    if (activeFilters.has(kind)) activeFilters.delete(kind);
    else activeFilters.add(kind);
    button.classList.toggle('active', activeFilters.has(kind));
    updateMarkerVisibility();
    if (selectedId && !activeFilters.has(events.find(item => item.id === selectedId)?.kind)) {
      selectedId = null;
      setSelectedCard(null);
    }
  });
});

recenterBtn.addEventListener('click', () => {
  resetCamera();
  setAutospinState(false);
});

autospinBtn.addEventListener('click', () => {
  setAutospinState(!autoSpin);
  showStatus(autoSpin ? 'Auto spin engaged' : 'Auto spin paused');
});

renderer.domElement.addEventListener('pointerdown', () => {
  setAutospinState(false);
});

const raycaster = new THREE.Raycaster();
const pointer = new THREE.Vector2();

renderer.domElement.addEventListener('click', event => {
  pointer.x = (event.clientX / window.innerWidth) * 2 - 1;
  pointer.y = -(event.clientY / window.innerHeight) * 2 + 1;
  raycaster.setFromCamera(pointer, camera);
  const intersects = raycaster.intersectObjects(markerEntries.map(entry => entry.sprite), false);
  if (!intersects.length) return;
  const id = intersects[0].object.userData.eventId;
  focusEvent(id);
});

let coastlinesLoaded = false;
async function init() {
  if (!coastlinesLoaded) {
    await addLandOutlines();
    coastlinesLoaded = true;
  }
  const [quakes, eonetEvents] = await Promise.all([fetchQuakes(), fetchEonetEvents()]);
  events = [...quakes, ...eonetEvents].sort((a, b) => scoreEvent(b) - scoreEvent(a));
  rebuildMarkers();
  updateStats();
  selectedId = events[0]?.id || null;
  setSelectedCard(events[0] || null);
  renderEventList();
  panelUpdated.textContent = `Updated ${formatUpdated(new Date())}`;
  loadingCover.classList.add('hidden');
}

function scheduleRefresh() {
  clearInterval(refreshTimer);
  refreshTimer = setInterval(async () => {
    try {
      const [quakes, eonetEvents] = await Promise.all([fetchQuakes(), fetchEonetEvents()]);
      events = [...quakes, ...eonetEvents].sort((a, b) => scoreEvent(b) - scoreEvent(a));
      rebuildMarkers();
      updateStats();
      renderEventList();
      if (selectedId) {
        const selected = events.find(item => item.id === selectedId);
        setSelectedCard(selected || null);
      }
      panelUpdated.textContent = `Updated ${formatUpdated(new Date())}`;
      showStatus('Feeds refreshed');
    } catch (error) {
      console.warn('Feed refresh failed:', error);
    }
  }, 300000);
}

const clock = new THREE.Clock();

function animate() {
  requestAnimationFrame(animate);
  const elapsed = clock.getElapsedTime();
  controls.update();

  if (autoSpin && !userInteracting) {
    globeGroup.rotation.y += 0.0009;
  }

  markerEntries.forEach((entry, index) => {
    const pulse = 1 + Math.sin(elapsed * 2.2 + index * 0.35) * 0.12;
    entry.sprite.scale.setScalar(entry.baseScale * pulse);
  });

  if (focusVector) {
    camera.position.lerp(focusVector, 0.055);
    if (camera.position.distanceTo(focusVector) < 0.02) focusVector = null;
  }

  atmosphere.material.uniforms.viewVector.value = camera.position;
  renderer.render(scene, camera);
}

function handleResize() {
  const width = window.innerWidth;
  const height = window.innerHeight;
  camera.aspect = width / height;
  camera.updateProjectionMatrix();
  renderer.setSize(width, height);
}

window.addEventListener('resize', handleResize);

try {
  showStatus('Syncing official feeds');
  await init();
} catch (error) {
  console.error('Globe init failed:', error);
  loadingCover.classList.add('hidden');
  panelUpdated.textContent = 'Feed error';
  setSelectedCard({
    kind: 'quakes',
    title: 'Feed sync failed',
    place: 'One or more live sources did not respond cleanly.',
    source: 'Browser',
    time: new Date().toISOString(),
    url: 'https://koels.site/status'
  });
}
scheduleRefresh();
animate();
</script>
</body>
</html>
