---
// src/pages/legal.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Legal — koels.site</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%23020810'/%3E%3Ctext x='16' y='26' text-anchor='middle' font-family='Inter%2C system-ui%2C sans-serif' font-size='26' font-weight='900' fill='url(%23g)'%3EK%3C/text%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' stop-color='%2340c8ff'/%3E%3Cstop offset='100%25' stop-color='%2300ffcc'/%3E%3C/linearGradient%3E%3C/defs%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:      #020810;
  --bg2:     #040e1e;
  --surface: rgba(2,10,24,0.6);
  --border:  rgba(0,120,200,0.14);
  --border2: rgba(64,200,255,0.22);
  --text:    #c8f0ff;
  --muted:   rgba(200,240,255,0.5);
  --dim:     rgba(200,240,255,0.28);
  --accent:  #40c8ff;
  --teal:    #00ffcc;
  --red:     #ff4757;
  --white:   #e8f8ff;
  --sans: "Inter", system-ui, sans-serif;
  --mono: "JetBrains Mono", monospace;
  --ease: cubic-bezier(0.16, 1, 0.3, 1);
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box }
html { scroll-behavior:smooth; font-size:16px }
body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
a { color:inherit; text-decoration:none }

/* ── NOISE ── */
body::after {
  content:''; position:fixed; inset:0; pointer-events:none; z-index:9990;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
}

/* ── BLOBS ── */
.blobs { position:fixed; inset:0; pointer-events:none; z-index:0; overflow:hidden }
.blob { position:absolute; border-radius:50%; filter:blur(130px) }
.b1 { width:600px;height:500px;background:radial-gradient(#0050c8,transparent 70%);opacity:.18;top:-120px;left:-100px;animation:bm1 38s ease-in-out infinite }
.b2 { width:500px;height:500px;background:radial-gradient(#003080,transparent 70%);opacity:.14;bottom:10%;right:-100px;animation:bm2 48s ease-in-out infinite }
@keyframes bm1 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(40px,80px)} }
@keyframes bm2 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-50px,-60px)} }

/* ── HEADER ── */
header {
  position:fixed; top:0; left:0; right:0; z-index:500;
  height:58px; display:flex; align-items:center; justify-content:space-between;
  padding:0 40px;
  border-bottom:1px solid var(--border);
  background:rgba(2,8,16,0.7);
  backdrop-filter:blur(24px);
  -webkit-backdrop-filter:blur(24px);
}
.logo {
  font-family:var(--mono); font-size:0.7rem; font-weight:700;
  letter-spacing:0.2em; text-transform:uppercase; color:var(--white);
  display:flex; align-items:center; gap:9px;
}
.logo-dot {
  width:6px; height:6px; border-radius:50%;
  background:var(--teal); box-shadow:0 0 10px var(--teal);
  animation:dot-pulse 2s ease infinite;
}
@keyframes dot-pulse { 0%,100%{box-shadow:0 0 6px var(--teal)} 50%{box-shadow:0 0 20px var(--teal),0 0 40px rgba(0,255,204,0.2)} }
nav { display:flex; align-items:center; gap:28px }
nav a {
  font-family:var(--mono); font-size:0.7rem; letter-spacing:0.14em;
  color:var(--muted); text-transform:uppercase; transition:color 0.2s;
}
nav a:hover { color:var(--white) }

/* ── PAGE ── */
.page-wrap {
  max-width:800px; margin:0 auto;
  padding:110px 40px 80px;
  position:relative; z-index:1;
}

.page-hero { margin-bottom:64px }
.eyebrow {
  display:inline-flex; align-items:center; gap:10px;
  font-family:var(--mono); font-size:0.68rem; letter-spacing:0.22em;
  text-transform:uppercase; color:var(--accent); margin-bottom:24px;
  opacity:0; animation:fade-up 0.9s var(--ease) 0.1s both;
}
.eyebrow-line { width:24px; height:1px; background:var(--accent) }
.page-title {
  font-size:clamp(2.8rem, 6vw, 5rem);
  font-weight:900; line-height:0.92; letter-spacing:-0.03em; color:var(--white);
  opacity:0; animation:fade-up 0.9s 0.16s var(--ease) both;
}
.page-title .grad {
  background:linear-gradient(135deg, var(--accent) 0%, var(--teal) 60%, var(--accent) 100%);
  background-size:200% auto;
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  animation:shimmer 5s linear infinite;
}
@keyframes shimmer { to { background-position:200% center } }
.page-meta {
  margin-top:20px;
  font-family:var(--mono); font-size:0.68rem; letter-spacing:0.12em;
  color:var(--dim); text-transform:uppercase;
  opacity:0; animation:fade-up 0.9s 0.22s var(--ease) both;
}

/* ── TABS ── */
.tab-nav {
  display:flex; gap:0;
  border:1px solid var(--border2);
  border-radius:8px; overflow:hidden;
  margin-bottom:52px;
  opacity:0; animation:fade-up 0.9s 0.28s var(--ease) both;
}
.tab-btn {
  flex:1; padding:12px 20px;
  font-family:var(--mono); font-size:0.68rem; font-weight:600;
  letter-spacing:0.14em; text-transform:uppercase;
  background:transparent; color:var(--muted);
  border:none; cursor:pointer; transition:0.2s var(--ease);
}
.tab-btn + .tab-btn { border-left:1px solid var(--border2) }
.tab-btn.active {
  background:linear-gradient(135deg, rgba(64,200,255,0.15), rgba(0,255,204,0.08));
  color:var(--accent);
}
.tab-btn:not(.active):hover { background:rgba(64,200,255,0.05); color:var(--text) }

.panel { display:none }
.panel.active { display:block }

/* ── CONTENT ── */
.doc-section {
  margin-bottom:40px; padding-bottom:40px;
  border-bottom:1px solid var(--border);
}
.doc-section:last-child { border-bottom:none; margin-bottom:0; padding-bottom:0 }

.section-header { display:flex; align-items:baseline; gap:14px; margin-bottom:14px }
.section-num {
  font-family:var(--mono); font-size:0.62rem; letter-spacing:0.2em;
  color:var(--dim); text-transform:uppercase; flex-shrink:0;
}
.section-title {
  font-size:1rem; font-weight:700; color:var(--white); letter-spacing:-0.01em;
}
.doc-text {
  font-family:var(--mono); font-size:0.78rem; line-height:1.95;
  color:var(--muted); letter-spacing:0.02em;
}
.doc-text + .doc-text { margin-top:12px }

/* inline code */
code {
  color:var(--accent); background:rgba(64,200,255,0.08);
  padding:1px 7px; border-radius:4px; font-size:0.85em;
}

/* ── TABLE ── */
.data-table {
  width:100%; border-collapse:collapse; margin-top:20px;
  border:1px solid var(--border2); border-radius:8px; overflow:hidden;
}
.data-table th {
  font-family:var(--mono); font-size:0.62rem; letter-spacing:0.15em;
  text-transform:uppercase; color:var(--dim);
  background:rgba(4,18,40,0.7); padding:11px 16px;
  text-align:left; border-bottom:1px solid var(--border2);
}
.data-table td {
  font-family:var(--mono); font-size:0.74rem; color:var(--muted);
  padding:11px 16px; border-bottom:1px solid var(--border); line-height:1.6;
}
.data-table tr:last-child td { border-bottom:none }
.data-table tr:hover td { background:rgba(64,200,255,0.03) }
.badge {
  display:inline-flex; align-items:center;
  padding:2px 9px; border-radius:999px;
  font-size:0.6rem; letter-spacing:0.1em; font-weight:600; text-transform:uppercase;
}
.badge-teal { background:rgba(0,255,204,0.08); color:var(--teal); border:1px solid rgba(0,255,204,0.22) }

/* ── CALLOUTS ── */
.callout {
  display:flex; gap:12px; align-items:flex-start;
  padding:14px 18px; border-radius:8px; margin-top:16px;
}
.callout-promise {
  background:rgba(0,255,204,0.04);
  border:1px solid rgba(0,255,204,0.15);
}
.callout-warn {
  background:rgba(64,200,255,0.04);
  border:1px solid rgba(64,200,255,0.16);
}
.callout-icon { font-size:0.95rem; flex-shrink:0; margin-top:2px }
.callout-text {
  font-family:var(--mono); font-size:0.74rem; line-height:1.8;
  color:var(--muted); letter-spacing:0.02em;
}
.callout-promise .callout-text { color:rgba(0,255,204,0.8) }
.callout-warn .callout-text { color:rgba(64,200,255,0.85) }

/* ── FOOTER ── */
footer {
  display:flex; align-items:center; justify-content:space-between;
  padding:20px 40px; border-top:1px solid var(--border);
  max-width:800px; margin:0 auto;
  position:relative; z-index:1;
}
.foot-l { font-family:var(--mono); font-size:0.62rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--dim) }
.foot-links { display:flex; gap:20px }
.foot-links a { font-family:var(--mono); font-size:0.62rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--dim); transition:color 0.2s }
.foot-links a:hover { color:var(--accent) }

/* ── UTILS ── */
@keyframes fade-up { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
.reveal { opacity:0; transform:translateY(20px); transition:opacity 0.7s var(--ease), transform 0.7s var(--ease) }
.reveal.visible { opacity:1; transform:translateY(0) }

@media(max-width:700px) {
  header { padding:0 20px }
  nav { display:none }
  .page-wrap { padding:90px 20px 60px }
  footer { padding:20px; flex-direction:column; gap:10px; text-align:center }
  .data-table th, .data-table td { padding:10px 12px }
}
</style>
</head>
<body>

<div class="blobs" aria-hidden="true">
  <div class="blob b1"></div>
  <div class="blob b2"></div>
</div>

<header>
  <a href="/" class="logo"><div class="logo-dot"></div>Koels.site</a>
  <nav>
    <a href="/">Home</a>
    <a href="/links">Links</a>
  </nav>
</header>

<div class="page-wrap">

  <div class="page-hero">
    <div class="eyebrow"><span class="eyebrow-line"></span>Discord Bot</div>
    <h1 class="page-title"><span class="grad">Legal</span><br>Docs.</h1>
    <div class="page-meta">Last updated — April 2026 &nbsp;·&nbsp; Effective immediately</div>
  </div>

  <div class="tab-nav">
    <button class="tab-btn active" onclick="switchTab('tos', this)">Terms of Service</button>
    <button class="tab-btn" onclick="switchTab('privacy', this)">Privacy Policy</button>
  </div>

  <!-- TERMS OF SERVICE -->
  <div id="panel-tos" class="panel active">

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">01</span>
        <span class="section-title">The Basics</span>
      </div>
      <p class="doc-text">
        This is a private bot for my Minecraft server. By using it you agree to these terms. It's not public — it won't work anywhere else by design, and only authorized members of my server will ever interact with it.
      </p>
    </div>

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">02</span>
        <span class="section-title">Don't Abuse It</span>
      </div>
      <p class="doc-text">
        Use the bot for what it's for — verifying your Minecraft account. Don't try to spoof accounts, spam commands, or exploit it in any way.
      </p>
      <div class="callout callout-warn">
        <span class="callout-icon">⚠</span>
        <span class="callout-text">Breaking these rules can get you permanently banned from the server. No appeals guaranteed.</span>
      </div>
    </div>

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">03</span>
        <span class="section-title">Staff Rules</span>
      </div>
      <p class="doc-text">
        If you have a staff role with access to player data, you agree not to share, leak, or misuse it — ever. You can only share info with explicit permission from me. Every use of staff commands is logged and may be audited.
      </p>
      <div class="callout callout-warn">
        <span class="callout-icon">⚠</span>
        <span class="callout-text">Leaking or selling player data is an instant demotion, no exceptions.</span>
      </div>
    </div>

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">04</span>
        <span class="section-title">Contact</span>
      </div>
      <p class="doc-text">
        Questions or concerns? Hit me up on Discord at <span style="color:var(--accent)">@koels</span> or email <span style="color:var(--accent)">kyle@koels.site</span>.
      </p>
    </div>

  </div>

  <!-- PRIVACY POLICY -->
  <div id="panel-privacy" class="panel">

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">01</span>
        <span class="section-title">What I Collect</span>
      </div>
      <p class="doc-text">When you verify, the bot collects your Minecraft username, UUID, Discord username, Discord ID, and IP address. That's it.</p>
      <table class="data-table">
        <thead>
          <tr>
            <th>Data</th>
            <th>Why</th>
            <th>Sold?</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Minecraft Username &amp; UUID</td>
            <td>Account verification &amp; linking</td>
            <td><span class="badge badge-teal">Never</span></td>
          </tr>
          <tr>
            <td>Discord Username &amp; ID</td>
            <td>Linking Discord to your MC account</td>
            <td><span class="badge badge-teal">Never</span></td>
          </tr>
          <tr>
            <td>IP Address</td>
            <td>Alt-account detection &amp; ban enforcement</td>
            <td><span class="badge badge-teal">Never</span></td>
          </tr>
        </tbody>
      </table>
      <div class="callout callout-promise" style="margin-top:20px">
        <span class="callout-icon">✦</span>
        <span class="callout-text">None of this is sold, shared, or used for anything outside of running the server. No ads, no bad intent.</span>
      </div>
    </div>

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">02</span>
        <span class="section-title">How It's Stored</span>
      </div>
      <p class="doc-text">
        Everything is stored locally on my personal computer, encrypted at rest with AES-256. The files are unreadable without the key — access is only possible through controlled bot commands, not by opening the files directly.
      </p>
      <p class="doc-text">
        Your IP is also obfuscated in server console logs — what shows up there is a fake placeholder, not your real address. The real IP is only ever visible via the <code>/view</code> command, which is staff-only, ephemeral, and fully logged.
      </p>
    </div>

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">03</span>
        <span class="section-title">Deletion</span>
      </div>
      <p class="doc-text">
        You can request the deletion of your data at any time by contacting me on Discord <span style="color:var(--accent)">@koels</span> or email <span style="color:var(--accent)">kyle@koels.site</span>. I will remove your verification record, IP address, and join history. Please note that if you have an active ban, the ban entry will remain, as it is necessary to enforce server rules.
      </p>
    </div>

    <div class="doc-section reveal">
      <div class="section-header">
        <span class="section-num">04</span>
        <span class="section-title">Changes</span>
      </div>
      <p class="doc-text">
        This policy may change over time. Updates will be reflected on this page. Continued use of the bot means you accept whatever's current.
      </p>
    </div>

  </div>

</div>

<footer>
  <span class="foot-l">© 2026 koels.site</span>
  <div class="foot-links">
    <a href="/">Home</a>
    <a href="/links">Links</a>
  </div>
</footer>

<script is:inline>
const obs = new IntersectionObserver(
  es => es.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible') }),
  { threshold: 0.08 }
);
document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

function switchTab(id, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('panel-' + id).classList.add('active');
  btn.classList.add('active');
  document.querySelectorAll('#panel-' + id + ' .reveal').forEach(el => {
    el.classList.remove('visible');
    setTimeout(() => el.classList.add('visible'), 60);
  });
}
</script>
</body>
</html>
