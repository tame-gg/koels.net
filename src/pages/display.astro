---
// src/pages/display.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Display — koels.site</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%23020810'/%3E%3Ctext x='16' y='26' text-anchor='middle' font-family='Inter%2C system-ui%2C sans-serif' font-size='26' font-weight='900' fill='url(%23g)'%3EK%3C/text%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' stop-color='%2340c8ff'/%3E%3Cstop offset='100%25' stop-color='%2300ffcc'/%3E%3C/linearGradient%3E%3C/defs%3E%3C/svg%3E">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    @view-transition { navigation: auto; }

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg:      #020810;
      --border:  rgba(0,120,200,0.14);
      --border2: rgba(64,200,255,0.22);
      --text:    #c8f0ff;
      --muted:   rgba(200,240,255,0.5);
      --dim:     rgba(200,240,255,0.28);
      --cyan:    #40c8ff;
      --teal:    #00ffcc;
      --ease:    cubic-bezier(0.16,1,0.3,1);
      --mono:    'JetBrains Mono', monospace;
      --sans:    'Inter', system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--sans);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* noise */
    body::after {
      content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 9990;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    }

    /* aurora */
    .blobs { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
    .blob  { position: absolute; border-radius: 50%; filter: blur(120px); }
    .b1 { width:700px;height:560px;background:radial-gradient(#0050c8,transparent 70%);opacity:.22;top:-150px;left:-150px;animation:bm1 35s ease-in-out infinite }
    .b2 { width:600px;height:600px;background:radial-gradient(#003080,transparent 70%);opacity:.18;top:-100px;right:-150px;animation:bm2 45s ease-in-out infinite }
    .b3 { width:550px;height:440px;background:radial-gradient(#00a8b0,transparent 70%);opacity:.16;bottom:5%;left:10%;animation:bm3 28s ease-in-out infinite }
    .b4 { width:480px;height:480px;background:radial-gradient(#0070c0,transparent 70%);opacity:.14;bottom:0;right:5%;animation:bm4 50s ease-in-out infinite }
    @keyframes bm1{0%,100%{transform:translate(0,0)scale(1)}40%{transform:translate(60px,80px)scale(1.08)}70%{transform:translate(20px,140px)scale(.94)}}
    @keyframes bm2{0%,100%{transform:translate(0,0)scale(1)}30%{transform:translate(-70px,100px)scale(1.1)}65%{transform:translate(-30px,180px)scale(.9)}}
    @keyframes bm3{0%,100%{transform:translate(0,0)scale(1)}45%{transform:translate(60px,-70px)scale(1.1)}}
    @keyframes bm4{0%,100%{transform:translate(0,0)scale(1)}40%{transform:translate(-50px,-90px)scale(1.07)}}

    /* header */
    header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      height: 56px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 32px;
      background: rgba(2,8,16,0.7);
      border-bottom: 1px solid var(--border);
      backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
    }

    .logo {
      font-family: var(--mono); font-size: 0.68rem; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase; color: #e8f8ff;
      display: flex; align-items: center; gap: 8px;
      text-decoration: none;
    }
    .logo-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--teal); box-shadow: 0 0 10px var(--teal);
      animation: dot-pulse 2s ease infinite; flex-shrink: 0;
    }
    @keyframes dot-pulse{0%,100%{box-shadow:0 0 6px var(--teal)}50%{box-shadow:0 0 20px var(--teal),0 0 40px rgba(0,255,204,0.2)}}

    .header-actions { display: flex; align-items: center; gap: 10px; }

    .btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 7px 16px; border-radius: 6px;
      font-family: var(--mono); font-size: 0.65rem; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase;
      cursor: pointer; border: 1px solid transparent; transition: 0.2s var(--ease);
      text-decoration: none;
    }
    .btn-primary {
      background: var(--cyan); color: #010810; border-color: var(--cyan);
      box-shadow: 0 0 20px rgba(64,200,255,0.2);
    }
    .btn-primary:hover { background: #2ab0e8; border-color: #2ab0e8; }
    .btn-ghost {
      background: transparent; color: var(--muted); border-color: var(--border2);
    }
    .btn-ghost:hover { color: #e8f8ff; border-color: rgba(64,200,255,0.3); background: rgba(0,120,200,0.08); }

    /* main */
    main {
      position: relative; z-index: 1;
      min-height: 100vh;
      padding-top: 56px;
      display: flex; flex-direction: column;
    }

    /* drop zone */
    #drop-zone {
      flex: 1;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 20px;
      padding: 60px 24px;
      cursor: pointer;
      transition: background 0.2s;
    }
    #drop-zone.drag-over {
      background: rgba(64,200,255,0.04);
    }

    .drop-ring {
      width: 120px; height: 120px; border-radius: 50%;
      border: 1px solid var(--border2);
      display: flex; align-items: center; justify-content: center;
      transition: border-color 0.2s, box-shadow 0.2s;
      position: relative;
    }
    #drop-zone.drag-over .drop-ring,
    #drop-zone:hover .drop-ring {
      border-color: var(--cyan);
      box-shadow: 0 0 32px rgba(64,200,255,0.15);
    }
    .drop-ring svg {
      width: 36px; height: 36px;
      color: var(--dim);
      transition: color 0.2s;
    }
    #drop-zone:hover .drop-ring svg,
    #drop-zone.drag-over .drop-ring svg { color: var(--cyan); }

    .drop-label {
      font-family: var(--mono); font-size: 0.7rem; font-weight: 700;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--muted); text-align: center;
    }
    .drop-sub {
      font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--dim); text-align: center;
      margin-top: -10px;
    }

    #file-input { display: none; }

    /* image view */
    #image-view {
      display: none;
      flex: 1;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 32px 24px;
      gap: 20px;
    }
    #image-view.visible { display: flex; }

    #displayed-img {
      max-width: 100%;
      max-height: calc(100vh - 180px);
      border-radius: 10px;
      box-shadow: 0 24px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(64,200,255,0.08);
      object-fit: contain;
      animation: img-in 0.4s var(--ease) both;
    }
    @keyframes img-in { from{opacity:0;transform:scale(0.97)} to{opacity:1;transform:scale(1)} }

    .img-meta {
      font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--dim);
      text-align: center;
    }

    /* toast */
    .toast {
      position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%) translateY(12px);
      background: rgba(2,12,28,0.92); backdrop-filter: blur(16px);
      border: 1px solid var(--border2);
      color: var(--teal); font-family: var(--mono); font-size: 0.62rem;
      letter-spacing: 0.12em; text-transform: uppercase;
      padding: 10px 20px; border-radius: 6px;
      opacity: 0; transition: opacity 0.3s, transform 0.3s;
      z-index: 9999; pointer-events: none;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    @media(max-width: 600px) {
      header { padding: 0 16px; }
    }
  </style>
</head>
<body>

<div class="blobs" aria-hidden="true">
  <div class="blob b1"></div>
  <div class="blob b2"></div>
  <div class="blob b3"></div>
  <div class="blob b4"></div>
</div>

<div class="toast" id="toast"></div>

<header>
  <a href="/" class="logo"><div class="logo-dot"></div>Koels.site</a>
  <div class="header-actions">
    <button class="btn btn-ghost" id="clear-btn" style="display:none" onclick="clearImage()">Clear</button>
    <button class="btn btn-primary" onclick="document.getElementById('file-input').click()">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      Upload
    </button>
  </div>
</header>

<input type="file" id="file-input" accept="image/*">

<main>

  <!-- drop zone (shown when no image) -->
  <div id="drop-zone">
    <div class="drop-ring">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
      </svg>
    </div>
    <div class="drop-label">Drop an image here</div>
    <div class="drop-sub">or click to upload &nbsp;·&nbsp; paste with Ctrl+V</div>
  </div>

  <!-- image view (shown when image loaded) -->
  <div id="image-view">
    <img id="displayed-img" src="" alt="Displayed image">
    <div class="img-meta" id="img-meta"></div>
  </div>

</main>

<script is:inline>
if ('scrollRestoration' in history) history.scrollRestoration = 'manual';

const dropZone   = document.getElementById('drop-zone');
const imageView  = document.getElementById('image-view');
const displayedImg = document.getElementById('displayed-img');
const imgMeta    = document.getElementById('img-meta');
const fileInput  = document.getElementById('file-input');
const clearBtn   = document.getElementById('clear-btn');
const toast      = document.getElementById('toast');

function showToast(msg) {
  toast.textContent = msg;
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), 2200);
}

function loadImage(file) {
  if (!file || !file.type.startsWith('image/')) {
    showToast('Not an image file');
    return;
  }
  const reader = new FileReader();
  reader.onload = e => {
    displayedImg.src = e.target.result;
    displayedImg.onload = () => {
      const w = displayedImg.naturalWidth;
      const h = displayedImg.naturalHeight;
      imgMeta.textContent = `${file.name}  ·  ${w} × ${h}  ·  ${(file.size / 1024).toFixed(0)} KB`;
    };
    dropZone.style.display = 'none';
    imageView.classList.add('visible');
    clearBtn.style.display = '';
    showToast('Image loaded');
  };
  reader.readAsDataURL(file);
}

function clearImage() {
  displayedImg.src = '';
  imgMeta.textContent = '';
  imageView.classList.remove('visible');
  dropZone.style.display = '';
  clearBtn.style.display = 'none';
  fileInput.value = '';
}

// file input
fileInput.addEventListener('change', e => {
  if (e.target.files[0]) loadImage(e.target.files[0]);
});

// click drop zone
dropZone.addEventListener('click', () => fileInput.click());

// drag and drop
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', e => {
  e.preventDefault();
  dropZone.classList.remove('drag-over');
  const file = e.dataTransfer.files[0];
  if (file) loadImage(file);
});

// drag over whole page when image is already showing
document.addEventListener('dragover', e => e.preventDefault());
document.addEventListener('drop', e => {
  e.preventDefault();
  const file = e.dataTransfer.files[0];
  if (file) loadImage(file);
});

// paste (Ctrl+V)
document.addEventListener('paste', e => {
  const items = e.clipboardData?.items;
  if (!items) return;
  for (const item of items) {
    if (item.type.startsWith('image/')) {
      loadImage(item.getAsFile());
      break;
    }
  }
});
</script>

</body>
</html>
