---
// src/pages/ping.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>koels.site — Ping</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%2303030a'/%3E%3Ctext x='16' y='26' text-anchor='middle' font-family='Inter%2C system-ui%2C sans-serif' font-size='26' font-weight='900' fill='url(%23g)'%3EK%3C/text%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' stop-color='%23a29bfe'/%3E%3Cstop offset='100%25' stop-color='%236c5ce7'/%3E%3C/linearGradient%3E%3C/defs%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
<style is:global>
:root {
  --bg:       #03030a;
  --bg2:      #08080f;
  --surface:  #0f0f1a;
  --surface2: #141420;
  --border:   rgba(255,255,255,0.07);
  --border2:  rgba(255,255,255,0.12);
  --text:     #f0eeff;
  --muted:    rgba(240,238,255,0.68);
  --dim:      rgba(240,238,255,0.4);
  --accent:   #6c5ce7;
  --accent2:  #a29bfe;
  --lime:     #00ff88;
  --white:    #ffffff;
  --sans: "Inter", system-ui, sans-serif;
  --mono: "JetBrains Mono", monospace;
  --ease: cubic-bezier(0.16, 1, 0.3, 1);
}
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box }
html { scroll-behavior:smooth; font-size:17px }
body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
a { color:inherit; text-decoration:none }

body::after {
  content:''; position:fixed; inset:0; pointer-events:none; z-index:9990;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
}

/* ── CURTAIN ── */
#curtain {
  position:fixed; inset:0; background:var(--bg); z-index:9997;
  display:flex; align-items:center; justify-content:center;
  transition:opacity 0.8s var(--ease), visibility 0.8s;
}
#curtain.gone { opacity:0; visibility:hidden; pointer-events:none }
.curtain-logo {
  font-family:var(--mono); font-size:0.85rem; letter-spacing:0.25em;
  color:var(--dim); text-transform:uppercase;
  animation:curtain-pulse 1s ease infinite;
}
@keyframes curtain-pulse { 0%,100%{opacity:0.3} 50%{opacity:1} }

/* ── HEADER ── */
header {
  position:fixed; top:0; left:0; right:0; z-index:500;
  height:60px;
  display:flex; align-items:center; justify-content:space-between;
  padding:0 40px;
  border-bottom:1px solid var(--border);
  background:rgba(3,3,10,0.85);
  backdrop-filter:blur(24px) saturate(1.8);
  -webkit-backdrop-filter:blur(24px) saturate(1.8);
}
.logo {
  font-family:var(--mono); font-size:0.7rem; font-weight:700;
  letter-spacing:0.2em; text-transform:uppercase; color:var(--white);
  display:flex; align-items:center; gap:10px;
}
.logo-pulse {
  width:6px; height:6px; border-radius:50%;
  background:var(--lime); box-shadow:0 0 10px var(--lime);
  animation:lg-pulse 2s ease infinite;
}
@keyframes lg-pulse { 0%,100%{box-shadow:0 0 6px var(--lime)} 50%{box-shadow:0 0 20px var(--lime),0 0 40px rgba(0,255,136,0.25)} }

.nav { display:flex; align-items:center; gap:32px }
.nav a {
  font-family:var(--mono); font-size:0.72rem; letter-spacing:0.14em;
  color:var(--muted); text-transform:uppercase; transition:color 0.2s;
}
.nav a:hover { color:var(--white) }

/* ── HERO ── */
.hero {
  padding:160px 56px 80px;
  position:relative;
}
.hero::before {
  content:''; position:absolute; inset:0;
  background-image:
    linear-gradient(var(--border) 1px, transparent 1px),
    linear-gradient(90deg, var(--border) 1px, transparent 1px);
  background-size:64px 64px;
  mask-image:radial-gradient(ellipse 90% 90% at 50% 50%, black 0%, transparent 100%);
  -webkit-mask-image:radial-gradient(ellipse 90% 90% at 50% 50%, black 0%, transparent 100%);
  opacity:0.5; pointer-events:none; z-index:0;
}
.hero-glow {
  position:absolute; top:30%; left:50%;
  transform:translate(-50%,-50%);
  width:700px; height:700px;
  background:radial-gradient(circle, rgba(108,92,231,0.1) 0%, transparent 60%);
  pointer-events:none; z-index:0;
}
.hero-content { position:relative; z-index:2; max-width:720px; }

.eyebrow {
  display:inline-flex; align-items:center; gap:10px;
  font-family:var(--mono); font-size:0.72rem; font-weight:500;
  letter-spacing:0.2em; text-transform:uppercase; color:var(--accent2);
  margin-bottom:32px;
  animation:fade-up 0.9s var(--ease) both;
}
.eyebrow-line { width:28px; height:1px; background:var(--accent) }

h1 {
  font-family:var(--sans);
  font-size:clamp(2.8rem, 5.5vw, 5.5rem);
  font-weight:900; line-height:0.9;
  letter-spacing:-0.04em; color:var(--white);
  animation:fade-up 0.9s 0.07s var(--ease) both;
}
h1 .grad {
  background:linear-gradient(135deg, var(--accent2) 0%, #c084fc 50%, var(--accent2) 100%);
  background-size:200% auto;
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  animation:shimmer 4s linear infinite;
}
@keyframes shimmer { to { background-position:200% center } }

.hero-desc {
  margin-top:28px;
  font-family:var(--mono); font-size:0.85rem; line-height:1.9;
  color:var(--muted); letter-spacing:0.04em; max-width:520px;
  animation:fade-up 0.9s 0.14s var(--ease) both;
}

.hero-back {
  margin-top:44px;
  animation:fade-up 0.9s 0.21s var(--ease) both;
}
.back-link {
  display:inline-flex; align-items:center; gap:8px;
  font-family:var(--mono); font-size:0.68rem; font-weight:700;
  letter-spacing:0.12em; text-transform:uppercase;
  color:var(--accent2); transition:color 0.2s;
}
.back-link:hover { color:var(--white) }
.back-link svg { width:13px; height:13px; fill:currentColor; }

/* ── PING METRICS ── */
.metrics-section {
  display:grid; grid-template-columns:240px 1fr;
  border-bottom:1px solid var(--border);
}
.metrics-sidebar { padding:64px 40px; border-right:1px solid var(--border) }
.sec-idx { font-family:var(--mono); font-size:0.65rem; letter-spacing:0.2em; color:var(--dim); text-transform:uppercase; margin-bottom:10px }
.sec-title { font-family:var(--sans); font-size:1.1rem; font-weight:600; color:var(--muted); letter-spacing:-0.01em }

.metrics-body { padding:64px 64px }

/* Big ping number */
.ping-hero {
  display:flex; align-items:baseline; gap:16px; margin-bottom:8px;
}
.ping-value {
  font-family:var(--sans); font-size:4.5rem; font-weight:900;
  letter-spacing:-0.06em; line-height:1; color:var(--lime);
  text-shadow:0 0 50px rgba(0,255,136,0.2);
}
.ping-unit {
  font-family:var(--mono); font-size:0.85rem; letter-spacing:0.1em;
  text-transform:uppercase; color:var(--dim);
}
.ping-label {
  font-family:var(--mono); font-size:0.62rem; letter-spacing:0.14em;
  text-transform:uppercase; color:var(--dim); margin-bottom:48px;
}

/* Metric grid */
.metric-grid {
  display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr));
  gap:12px;
}
.metric-card {
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:12px;
  padding:20px 24px;
  transition:border-color 0.2s, transform 0.2s;
  animation:fade-up 0.5s var(--ease) both;
}
.metric-card:hover { border-color:var(--border2); transform:translateY(-1px); }
.metric-label {
  font-family:var(--mono); font-size:0.55rem; letter-spacing:0.16em;
  text-transform:uppercase; color:var(--dim); margin-bottom:10px;
}
.metric-value {
  font-family:var(--mono); font-size:1.05rem; font-weight:700;
  color:var(--text); letter-spacing:0.02em; word-break:break-all;
}
.metric-sub {
  font-family:var(--mono); font-size:0.58rem; color:var(--dim);
  margin-top:4px; letter-spacing:0.04em;
}

/* Latency bars */
.latency-bars { margin-top:32px; }
.latency-bars-title {
  font-family:var(--mono); font-size:0.62rem; letter-spacing:0.14em;
  text-transform:uppercase; color:var(--dim); margin-bottom:16px;
}
.bar-row {
  display:flex; align-items:center; gap:12px; margin-bottom:8px;
}
.bar-label {
  font-family:var(--mono); font-size:0.55rem; color:var(--dim);
  width:60px; text-align:right; flex-shrink:0;
}
.bar-track {
  flex:1; height:4px; background:rgba(255,255,255,0.04); border-radius:999px; overflow:hidden;
}
.bar-fill {
  height:100%; border-radius:999px;
  background:linear-gradient(90deg, var(--accent), var(--lime));
  width:0%; transition:width 0.6s var(--ease);
}
.bar-ms {
  font-family:var(--mono); font-size:0.55rem; color:var(--muted);
  width:48px; flex-shrink:0;
}

/* ── FOOTER ── */
footer {
  display:flex; align-items:center; justify-content:space-between; padding:22px 48px;
}
.foot-l, .foot-r { font-family:var(--mono); font-size:0.68rem; letter-spacing:0.12em; color:var(--dim); text-transform:uppercase }
.foot-r { display:flex; gap:18px }

/* ── UTILS ── */
@keyframes fade-up { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
.reveal { opacity:0; transform:translateY(22px); transition:opacity 0.7s var(--ease), transform 0.7s var(--ease) }
.reveal.visible { opacity:1; transform:translateY(0) }

@media(max-width:860px){
  header { padding:0 20px }
  .nav { display:none }
  .hero { padding:130px 20px 56px }
  .metrics-section { grid-template-columns:1fr }
  .metrics-sidebar { border-right:none; border-bottom:1px solid var(--border); padding:40px 24px 0 }
  .metrics-body { padding:28px 20px 40px }
  .metric-grid { grid-template-columns:1fr }
  .ping-value { font-size:3rem; }
  footer { flex-direction:column; gap:10px; text-align:center }
}
</style>
</head>
<body>

<div id="curtain"><div class="curtain-logo">koels.site</div></div>

<!-- HEADER -->
<header>
  <div class="logo"><div class="logo-pulse"></div>Koels.site</div>
  <nav class="nav">
    <a href="/">Home</a>
    <a href="/links">Links</a>
    <a href="/radar">Radar</a>
  </nav>
</header>

<!-- HERO -->
<section class="hero">
  <div class="hero-glow"></div>
  <div class="hero-content">
    <div class="eyebrow"><span class="eyebrow-line"></span>Ping</div>
    <h1><span class="grad">How Fast</span> is<br>Your Connection?</h1>
    <p class="hero-desc">
      Real-time latency measurements, browser diagnostics, and connection quality — all computed client-side.
    </p>
    <div class="hero-back">
      <a href="/" class="back-link">
        <svg viewBox="0 0 24 24"><path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z"/></svg>
        Back to home
      </a>
    </div>
  </div>
</section>

<div style="height:1px;background:linear-gradient(90deg,transparent,var(--border2),transparent);"></div>

<!-- METRICS -->
<div class="metrics-section">
  <div class="metrics-sidebar reveal">
    <div class="sec-idx">01 / Diagnostics</div>
    <div class="sec-title">Your Connection</div>
  </div>
  <div class="metrics-body reveal" style="transition-delay:.1s">

    <!-- Big ping number -->
    <div class="ping-hero">
      <div class="ping-value" id="ping-live">—</div>
      <div class="ping-unit">ms</div>
    </div>
    <div class="ping-label">Latency to koels.site</div>

    <!-- Metric cards -->
    <div class="metric-grid" id="metric-grid">
      <div class="metric-card" style="animation-delay:0.05s">
        <div class="metric-label">Round Trip</div>
        <div class="metric-value" id="m-rtt">Measuring…</div>
        <div class="metric-sub">Effective RTT</div>
      </div>
      <div class="metric-card" style="animation-delay:0.1s">
        <div class="metric-label">Jitter</div>
        <div class="metric-value" id="m-jitter">—</div>
        <div class="metric-sub">Latency variance</div>
      </div>
      <div class="metric-card" style="animation-delay:0.15s">
        <div class="metric-label">Protocol</div>
        <div class="metric-value" id="m-protocol">—</div>
        <div class="metric-sub">Connection type</div>
      </div>
      <div class="metric-card" style="animation-delay:0.2s">
        <div class="metric-label">Downlink</div>
        <div class="metric-value" id="m-downlink">—</div>
        <div class="metric-sub">Estimated Mbps</div>
      </div>
      <div class="metric-card" style="animation-delay:0.25s">
        <div class="metric-label">Screen</div>
        <div class="metric-value" id="m-screen">—</div>
        <div class="metric-sub">Display resolution</div>
      </div>
      <div class="metric-card" style="animation-delay:0.3s">
        <div class="metric-label">Browser</div>
        <div class="metric-value" id="m-browser">—</div>
        <div class="metric-sub">User agent engine</div>
      </div>
      <div class="metric-card" style="animation-delay:0.35s">
        <div class="metric-label">Platform</div>
        <div class="metric-value" id="m-platform">—</div>
        <div class="metric-sub">Operating system</div>
      </div>
      <div class="metric-card" style="animation-delay:0.4s">
        <div class="metric-label">Cores</div>
        <div class="metric-value" id="m-cores">—</div>
        <div class="metric-sub">CPU threads</div>
      </div>
      <div class="metric-card" style="animation-delay:0.45s">
        <div class="metric-label">Memory</div>
        <div class="metric-value" id="m-memory">—</div>
        <div class="metric-sub">Device RAM</div>
      </div>
      <div class="metric-card" style="animation-delay:0.5s">
        <div class="metric-label">Color Depth</div>
        <div class="metric-value" id="m-color">—</div>
        <div class="metric-sub">Bits per pixel</div>
      </div>
      <div class="metric-card" style="animation-delay:0.55s">
        <div class="metric-label">Touch</div>
        <div class="metric-value" id="m-touch">—</div>
        <div class="metric-sub">Touch support</div>
      </div>
      <div class="metric-card" style="animation-delay:0.6s">
        <div class="metric-label">Timezone</div>
        <div class="metric-value" id="m-tz">—</div>
        <div class="metric-sub">Local timezone</div>
      </div>
    </div>

  </div>
</div>

<!-- FOOTER -->
<footer>
  <div class="foot-l">© 2026 Koels.site</div>
  <div class="foot-r">
    <a href="/">Home</a>
    <span>·</span>
    <a href="/links">Links</a>
    <span>·</span>
    <a href="/radar">Radar</a>
    <span>·</span>
    <a href="/speedtest">Speedtest</a>
  </div>
</footer>

<script is:inline>
/* Curtain */
window.addEventListener('load',()=>setTimeout(()=>document.getElementById('curtain').classList.add('gone'),650))

/* Scroll reveal */
const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible')}),{threshold:0.1})
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el))

/* ── PING / LATENCY ── */
const pingLive = document.getElementById('ping-live');
const history = [];
const MAX_HISTORY = 20;

async function ping() {
  const start = performance.now();
  try {
    await fetch(window.location.href, { method:'HEAD', cache:'no-store' });
    const ms = Math.round(performance.now() - start);
    return ms;
  } catch {
    return null;
  }
}

function updateGrid(ms) {
  if (ms === null) return;

  history.push(ms);
  if (history.length > MAX_HISTORY) history.shift();

  /* Live number */
  pingLive.textContent = ms;
  pingLive.style.color = ms < 100 ? '#00ff88' : ms < 250 ? '#ffd60a' : '#ff4757';
  pingLive.style.textShadow = ms < 100 ? '0 0 50px rgba(0,255,136,0.2)' : ms < 250 ? '0 0 50px rgba(255,214,10,0.2)' : '0 0 50px rgba(255,71,87,0.2)';

  /* RTT */
  const avg = Math.round(history.reduce((a,b)=>a+b,0) / history.length);
  document.getElementById('m-rtt').textContent = avg + ' ms';

  /* Jitter */
  if (history.length > 1) {
    const diffs = [];
    for (let i = 1; i < history.length; i++) diffs.push(Math.abs(history[i] - history[i-1]));
    const jitter = Math.round(diffs.reduce((a,b)=>a+b,0) / diffs.length);
    document.getElementById('m-jitter').textContent = jitter + ' ms';
  }
}

/* Run pings */
(async () => {
  /* Initial ping */
  const ms = await ping();
  updateGrid(ms);

  /* Continue pinging every 3s */
  setInterval(async () => {
    const m = await ping();
    updateGrid(m);
  }, 3000);
})();

/* ── DIAGNOSTICS ── */
/* Protocol */
const conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
if (conn) {
  document.getElementById('m-protocol').textContent = (conn.effectiveType || 'unknown').toUpperCase();
  document.getElementById('m-downlink').textContent = (conn.downlink || '?') + ' Mbps';
} else {
  document.getElementById('m-protocol').textContent = 'N/A';
  document.getElementById('m-downlink').textContent = 'N/A';
}

/* Screen */
document.getElementById('m-screen').textContent = `${screen.width} × ${screen.height}`;

/* Browser detection */
const ua = navigator.userAgent;
let browser = 'Unknown';
if (ua.includes('Edg/')) browser = 'Edge';
else if (ua.includes('Chrome/')) browser = 'Chrome';
else if (ua.includes('Firefox/')) browser = 'Firefox';
else if (ua.includes('Safari/') && !ua.includes('Chrome/')) browser = 'Safari';
document.getElementById('m-browser').textContent = browser;

/* Platform */
let platform = 'Unknown';
if (ua.includes('Windows')) platform = 'Windows';
else if (ua.includes('Mac OS')) platform = 'macOS';
else if (ua.includes('Linux')) platform = 'Linux';
else if (ua.includes('Android')) platform = 'Android';
else if (ua.includes('iPhone') || ua.includes('iPad')) platform = 'iOS';
document.getElementById('m-platform').textContent = platform;

/* Cores */
document.getElementById('m-cores').textContent = navigator.hardwareConcurrency || '?';

/* Memory */
const mem = navigator.deviceMemory;
document.getElementById('m-memory').textContent = mem ? mem + ' GB' : 'N/A';

/* Color depth */
document.getElementById('m-color').textContent = screen.colorDepth + '-bit';

/* Touch */
document.getElementById('m-touch').textContent = ('ontouchstart' in window || navigator.maxTouchPoints > 0) ? 'Yes (' + navigator.maxTouchPoints + ' points)' : 'No';

/* Timezone */
document.getElementById('m-tz').textContent = Intl.DateTimeFormat().resolvedOptions().timeZone;
</script>
</body>
</html>
