---
// src/pages/status.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title>Status — koels.site</title>
<meta name="description" content="Live service status for koels.site — Minecraft server, radar, and more." />
<meta property="og:title" content="Status — koels.site" />
<meta property="og:description" content="Live service status for koels.site." />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://koels.site/status" />
<meta name="twitter:card" content="summary_large_image" />
<link rel="canonical" href="https://koels.site/status" />
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%23020810'/%3E%3Ctext x='16' y='26' text-anchor='middle' font-family='Inter%2C system-ui%2C sans-serif' font-size='26' font-weight='900' fill='url(%23g)'%3EK%3C/text%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' stop-color='%2340c8ff'/%3E%3Cstop offset='100%25' stop-color='%2300ffcc'/%3E%3C/linearGradient%3E%3C/defs%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
@view-transition { navigation: auto; }

:root {
  --bg:      #020810;
  --text:    #c8f0ff;
  --muted:   rgba(200,240,255,0.5);
  --dim:     rgba(200,240,255,0.28);
  --border:  rgba(0,120,200,0.14);
  --border2: rgba(64,200,255,0.22);
  --accent:  #40c8ff;
  --teal:    #00ffcc;
  --red:     #ff4757;
  --amber:   #ffa502;
  --sans:    'Inter', system-ui, sans-serif;
  --mono:    'JetBrains Mono', monospace;
  --ease:    cubic-bezier(0.16,1,0.3,1);
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box }
html { scroll-behavior:smooth }
body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  min-height: 100vh;
}
a { color:inherit; text-decoration:none }

/* ── NOISE ── */
body::after {
  content:''; position:fixed; inset:0; pointer-events:none; z-index:9990;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
}

/* ── BLOBS ── */
.blobs { position:fixed; inset:0; pointer-events:none; z-index:0; overflow:hidden }
.blob { position:absolute; border-radius:50%; filter:blur(120px) }
.b1 { width:600px;height:500px;background:radial-gradient(#0050c8,transparent 70%);opacity:.18;top:-150px;left:-100px;animation:bm1 35s ease-in-out infinite }
.b2 { width:500px;height:500px;background:radial-gradient(#003080,transparent 70%);opacity:.14;bottom:10%;right:-100px;animation:bm2 45s ease-in-out infinite }
@keyframes bm1 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(40px,80px) scale(1.06)} }
@keyframes bm2 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(-50px,-60px) scale(1.04)} }

/* ── CURSOR GLOW ── */
.cursor-glow {
  position:fixed; pointer-events:none; z-index:2;
  width:700px; height:700px; border-radius:50%;
  background:radial-gradient(circle, rgba(64,200,255,0.055) 0%, transparent 65%);
  transform:translate(-50%,-50%);
  top:-350px; left:-350px; opacity:0; transition:opacity 0.4s;
}

/* ── HEADER ── */
header {
  position:fixed; top:0; left:0; right:0; z-index:100;
  height:58px; display:flex; align-items:center; justify-content:space-between;
  padding:0 40px;
  background:rgba(2,8,16,0.7);
  border-bottom:1px solid var(--border);
  backdrop-filter:blur(24px); -webkit-backdrop-filter:blur(24px);
}
.logo {
  font-family:var(--mono); font-size:0.7rem; font-weight:700;
  letter-spacing:0.2em; text-transform:uppercase; color:#e8f8ff;
  display:flex; align-items:center; gap:9px;
}
.logo-dot {
  width:6px; height:6px; border-radius:50%;
  background:var(--teal); box-shadow:0 0 10px var(--teal);
  animation:dot-pulse 2s ease infinite;
}
@keyframes dot-pulse { 0%,100%{box-shadow:0 0 6px var(--teal)} 50%{box-shadow:0 0 20px var(--teal),0 0 40px rgba(0,255,204,0.2)} }
nav { display:flex; align-items:center; gap:28px }
nav a {
  font-family:var(--mono); font-size:0.7rem; letter-spacing:0.14em;
  color:var(--muted); text-transform:uppercase; transition:color 0.2s;
}
nav a:hover { color:#e8f8ff }
nav a.active { color:var(--accent) }

/* ── HAMBURGER ── */
.hamburger {
  display:none; flex-direction:column; gap:5px; cursor:pointer;
  padding:4px; background:none; border:none;
}
.hamburger span {
  display:block; width:20px; height:1.5px;
  background:var(--muted); border-radius:99px;
  transition:transform 0.25s var(--ease), opacity 0.2s;
}
.hamburger.open span:nth-child(1) { transform:translateY(6.5px) rotate(45deg); background:#e8f8ff }
.hamburger.open span:nth-child(2) { opacity:0 }
.hamburger.open span:nth-child(3) { transform:translateY(-6.5px) rotate(-45deg); background:#e8f8ff }

#mobile-menu {
  display:none; position:fixed; top:58px; left:0; right:0; z-index:99;
  background:rgba(2,8,16,0.97); border-bottom:1px solid var(--border);
  backdrop-filter:blur(24px); -webkit-backdrop-filter:blur(24px);
  flex-direction:column; padding:8px 0;
}
#mobile-menu.open { display:flex }
#mobile-menu a {
  font-family:var(--mono); font-size:0.72rem; letter-spacing:0.14em;
  text-transform:uppercase; color:var(--muted);
  padding:14px 24px; transition:color 0.2s, background 0.2s;
}
#mobile-menu a:hover { color:#e8f8ff; background:rgba(64,200,255,0.04) }
#mobile-menu a.active { color:var(--accent) }

/* ── PAGE ── */
.page {
  max-width:760px; margin:0 auto;
  padding:110px 40px 80px;
  position:relative; z-index:1;
}

/* ── PAGE HERO ── */
.page-eyebrow {
  display:inline-flex; align-items:center; gap:10px;
  font-family:var(--mono); font-size:0.68rem; letter-spacing:0.22em;
  text-transform:uppercase; color:var(--accent); margin-bottom:24px;
  opacity:0; animation:fade-up 0.9s var(--ease) 0.1s both;
}
.eyebrow-line { width:24px; height:1px; background:var(--accent) }
.page-title {
  font-size:clamp(2.6rem,6vw,4.5rem);
  font-weight:900; line-height:0.92; letter-spacing:-0.04em; color:#e8f8ff;
  margin-bottom:32px;
  opacity:0; animation:fade-up 0.9s var(--ease) 0.16s both;
}
.page-title .grad {
  background:linear-gradient(135deg, var(--accent) 0%, var(--teal) 60%, var(--accent) 100%);
  background-size:200% auto;
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  animation:shimmer 5s linear infinite;
}
@keyframes shimmer { to { background-position:200% center } }

/* ── OVERALL STATUS BANNER ── */
.status-banner {
  display:flex; align-items:center; justify-content:space-between; gap:16px;
  padding:18px 24px; border-radius:12px;
  border:1px solid var(--border);
  background:rgba(2,10,24,0.55);
  backdrop-filter:blur(16px);
  margin-bottom:40px;
  opacity:0; animation:fade-up 0.9s var(--ease) 0.22s both;
}
.banner-left { display:flex; align-items:center; gap:14px }
.banner-dot {
  width:12px; height:12px; border-radius:50%; flex-shrink:0;
  background:var(--teal); box-shadow:0 0 12px var(--teal);
  animation:pulse-green 2s ease infinite;
}
.banner-dot.degraded { background:var(--amber); box-shadow:0 0 12px var(--amber); animation:none }
.banner-dot.outage   { background:var(--red);   box-shadow:0 0 12px var(--red);   animation:none }
@keyframes pulse-green { 0%,100%{box-shadow:0 0 8px var(--teal)} 50%{box-shadow:0 0 22px var(--teal),0 0 40px rgba(0,255,204,0.15)} }
.banner-text {
  font-size:1rem; font-weight:700; color:#e8f8ff; letter-spacing:-0.01em;
}
.banner-sub {
  font-family:var(--mono); font-size:0.62rem; letter-spacing:0.1em;
  text-transform:uppercase; color:var(--dim); margin-top:2px;
}
.refresh-btn {
  display:inline-flex; align-items:center; gap:7px;
  font-family:var(--mono); font-size:0.62rem; font-weight:600;
  letter-spacing:0.12em; text-transform:uppercase;
  color:var(--dim); background:none; border:1px solid var(--border);
  border-radius:6px; padding:7px 14px; cursor:pointer;
  transition:color 0.2s, border-color 0.2s; flex-shrink:0;
}
.refresh-btn:hover { color:var(--accent); border-color:var(--border2) }
.refresh-icon { font-size:0.7rem; display:inline-block; transition:transform 0.5s var(--ease) }
.refresh-btn.spinning .refresh-icon { animation:spin 0.6s linear }
@keyframes spin { to { transform:rotate(360deg) } }

/* ── SERVICES ── */
.services-label {
  font-family:var(--mono); font-size:0.62rem; letter-spacing:0.18em;
  text-transform:uppercase; color:var(--dim); margin-bottom:16px;
  opacity:0; animation:fade-up 0.9s var(--ease) 0.28s both;
}
.services {
  display:flex; flex-direction:column; gap:0;
  border:1px solid var(--border); border-radius:12px; overflow:hidden;
  opacity:0; animation:fade-up 0.9s var(--ease) 0.33s both;
}
.service-row {
  display:flex; align-items:center; justify-content:space-between; gap:16px;
  padding:18px 24px;
  border-bottom:1px solid var(--border);
  background:rgba(2,10,24,0.4);
  transition:background 0.2s;
}
.service-row:last-child { border-bottom:none }
.service-row:hover { background:rgba(2,10,24,0.7) }

.svc-left { display:flex; align-items:center; gap:14px; min-width:0 }
.svc-icon {
  width:36px; height:36px; border-radius:9px; flex-shrink:0;
  background:rgba(64,200,255,0.07); border:1px solid rgba(64,200,255,0.12);
  display:flex; align-items:center; justify-content:center; font-size:1rem;
}
.svc-info { min-width:0 }
.svc-name {
  font-size:0.9rem; font-weight:700; color:#e8f8ff; letter-spacing:-0.01em;
}
.svc-desc {
  font-family:var(--mono); font-size:0.6rem; letter-spacing:0.08em;
  color:var(--dim); margin-top:2px;
}

.svc-right { display:flex; align-items:center; gap:20px; flex-shrink:0 }
.svc-ping {
  font-family:var(--mono); font-size:0.65rem; letter-spacing:0.06em;
  color:var(--dim); min-width:48px; text-align:right;
}
.svc-badge {
  display:inline-flex; align-items:center; gap:6px;
  font-family:var(--mono); font-size:0.62rem; font-weight:600;
  letter-spacing:0.12em; text-transform:uppercase;
  padding:5px 12px; border-radius:999px; border:1px solid;
  min-width:100px; justify-content:center;
}
.badge-checking {
  color:var(--dim); border-color:rgba(200,240,255,0.1);
  background:rgba(200,240,255,0.03);
}
.badge-up {
  color:var(--teal); border-color:rgba(0,255,204,0.3);
  background:rgba(0,255,204,0.06);
}
.badge-down {
  color:var(--red); border-color:rgba(255,71,87,0.3);
  background:rgba(255,71,87,0.06);
}
.badge-degraded {
  color:var(--amber); border-color:rgba(255,165,2,0.3);
  background:rgba(255,165,2,0.06);
}
.badge-dot {
  width:6px; height:6px; border-radius:50%; background:currentColor; flex-shrink:0;
}

/* ── LAST UPDATED ── */
.last-checked {
  margin-top:24px; text-align:right;
  font-family:var(--mono); font-size:0.6rem; letter-spacing:0.1em;
  text-transform:uppercase; color:var(--dim);
  opacity:0; animation:fade-up 0.9s var(--ease) 0.38s both;
}

/* ── FOOTER ── */
footer {
  display:flex; align-items:center; justify-content:space-between;
  padding:20px 40px; border-top:1px solid var(--border);
  max-width:760px; margin:0 auto;
  position:relative; z-index:1;
}
.foot-l { font-family:var(--mono); font-size:0.65rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--dim) }
.foot-links { display:flex; gap:20px }
.foot-links a { font-family:var(--mono); font-size:0.65rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--dim); transition:color 0.2s }
.foot-links a:hover { color:var(--accent) }

/* ── UTILS ── */
@keyframes fade-up { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

@media(max-width:700px) {
  header { padding:0 20px }
  nav { display:none }
  .hamburger { display:flex }
  .page { padding:90px 20px 60px }
  .status-banner { flex-direction:column; align-items:flex-start; gap:12px }
  .svc-ping { display:none }
  .svc-badge { min-width:80px }
  footer { padding:20px; flex-direction:column; gap:10px; text-align:center }
}
</style>
</head>
<body>

<div class="cursor-glow" id="cursorGlow" aria-hidden="true"></div>

<div class="blobs" aria-hidden="true">
  <div class="blob b1"></div>
  <div class="blob b2"></div>
</div>

<header>
  <a href="/" class="logo"><div class="logo-dot"></div>Koels.site</a>
  <nav>
    <a href="/">Home</a>
    <a href="/radar">Radar</a>
    <a href="/status" class="active">Status</a>
  </nav>
  <button class="hamburger" id="hamburger" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
    <span></span><span></span><span></span>
  </button>
</header>
<div id="mobile-menu">
  <a href="/" onclick="toggleMenu()">Home</a>
  <a href="/radar" onclick="toggleMenu()">Radar</a>
  <a href="/status" class="active" onclick="toggleMenu()">Status</a>
</div>

<div class="page">

  <div class="page-eyebrow"><span class="eyebrow-line"></span>Live</div>
  <h1 class="page-title"><span class="grad">System</span><br>Status.</h1>

  <div class="status-banner">
    <div class="banner-left">
      <div class="banner-dot" id="bannerDot"></div>
      <div>
        <div class="banner-text" id="bannerText">Checking…</div>
        <div class="banner-sub" id="bannerSub">Running checks</div>
      </div>
    </div>
    <button class="refresh-btn" id="refreshBtn" onclick="runChecks()">
      <span class="refresh-icon">↻</span> Refresh
    </button>
  </div>

  <div class="services-label">Services</div>

  <div class="services">

    <div class="service-row" id="svc-mc">
      <div class="svc-left">
        <div class="svc-icon">⛏️</div>
        <div class="svc-info">
          <div class="svc-name">koels.online</div>
          <div class="svc-desc">Minecraft server</div>
        </div>
      </div>
      <div class="svc-right">
        <div class="svc-ping" id="ping-mc">—</div>
        <div class="svc-badge badge-checking" id="badge-mc"><span class="badge-dot"></span>Checking</div>
      </div>
    </div>

    <div class="service-row" id="svc-radar">
      <div class="svc-left">
        <div class="svc-icon">🌩️</div>
        <div class="svc-info">
          <div class="svc-name">Radar</div>
          <div class="svc-desc">RainViewer tile API</div>
        </div>
      </div>
      <div class="svc-right">
        <div class="svc-ping" id="ping-radar">—</div>
        <div class="svc-badge badge-checking" id="badge-radar"><span class="badge-dot"></span>Checking</div>
      </div>
    </div>

  </div>

  <div class="last-checked" id="lastChecked">—</div>

</div>

<footer>
  <span class="foot-l">© 2026 koels.site</span>
  <div class="foot-links">
    <a href="/">Home</a>
    <a href="/radar">Radar</a>
  </div>
</footer>

<script is:inline>
// cursor spotlight
(function() {
  const glow = document.getElementById('cursorGlow');
  if (!glow) return;
  let visible = false, rafId = null;
  document.addEventListener('mousemove', e => {
    if (rafId) return;
    rafId = requestAnimationFrame(() => {
      glow.style.left = e.clientX + 'px';
      glow.style.top  = e.clientY + 'px';
      if (!visible) { glow.style.opacity = '1'; visible = true; }
      rafId = null;
    });
  });
  document.addEventListener('mouseleave', () => { glow.style.opacity = '0'; visible = false; });
})();

document.getElementById('hamburger').addEventListener('click', toggleMenu);
function toggleMenu() {
  const btn  = document.getElementById('hamburger');
  const menu = document.getElementById('mobile-menu');
  const open = btn.classList.toggle('open');
  menu.classList.toggle('open', open);
  btn.setAttribute('aria-expanded', open);
}

// ── STATUS CHECKS ──

function setBadge(id, state, label) {
  const el = document.getElementById('badge-' + id);
  el.className = 'svc-badge badge-' + state;
  el.innerHTML = '<span class="badge-dot"></span>' + label;
}

function setPing(id, ms) {
  const el = document.getElementById('ping-' + id);
  el.textContent = ms !== null ? ms + 'ms' : '—';
}

async function checkMC() {
  const t0 = performance.now();
  try {
    const res = await fetch('https://api.mcsrvstat.us/3/koels.online', { cache:'no-store' });
    const ms  = Math.round(performance.now() - t0);
    const d   = await res.json();
    if (d && d.online) {
      setPing('mc', ms);
      const p = d.players;
      setBadge('mc', 'up', 'Online');
      document.querySelector('#svc-mc .svc-desc').textContent =
        `${p.online} / ${p.max} players`;
      return 'up';
    } else {
      setBadge('mc', 'down', 'Offline');
      document.querySelector('#svc-mc .svc-desc').textContent = 'Minecraft server';
      return 'down';
    }
  } catch {
    setPing('mc', null);
    setBadge('mc', 'degraded', 'Unknown');
    return 'degraded';
  }
}

async function checkRadar() {
  const t0 = performance.now();
  try {
    const res = await fetch('https://api.rainviewer.com/public/weather-maps.json', { cache:'no-store' });
    const ms  = Math.round(performance.now() - t0);
    const d   = await res.json();
    if (d && d.radar) {
      setPing('radar', ms);
      setBadge('radar', 'up', 'Operational');
      return 'up';
    } else {
      setBadge('radar', 'degraded', 'Degraded');
      return 'degraded';
    }
  } catch {
    setPing('radar', null);
    setBadge('radar', 'down', 'Down');
    return 'down';
  }
}

function updateBanner(results) {
  const dot  = document.getElementById('bannerDot');
  const text = document.getElementById('bannerText');
  const sub  = document.getElementById('bannerSub');

  const hasDown     = results.includes('down');
  const hasDegraded = results.includes('degraded');

  if (hasDown) {
    dot.className  = 'banner-dot outage';
    text.textContent = 'Partial outage';
    sub.textContent  = 'One or more services are down';
  } else if (hasDegraded) {
    dot.className  = 'banner-dot degraded';
    text.textContent = 'Degraded performance';
    sub.textContent  = 'Some services may be unstable';
  } else {
    dot.className  = 'banner-dot';
    text.textContent = 'All systems operational';
    sub.textContent  = 'Everything looks good';
  }
}

function updateLastChecked() {
  const now = new Date();
  document.getElementById('lastChecked').textContent =
    'Last checked ' + now.toLocaleTimeString([], { hour:'2-digit', minute:'2-digit', second:'2-digit' });
}

let isChecking = false;

async function runChecks() {
  if (isChecking) return;
  isChecking = true;

  const btn = document.getElementById('refreshBtn');
  btn.classList.add('spinning');
  btn.disabled = true;

  // Reset all to checking
  ['mc','radar'].forEach(id => {
    setBadge(id, 'checking', 'Checking');
    setPing(id, null);
  });
  document.getElementById('bannerText').textContent = 'Checking…';
  document.getElementById('bannerSub').textContent  = 'Running checks';
  document.getElementById('bannerDot').className    = 'banner-dot';

  const results = await Promise.all([
    checkMC(),
    checkRadar(),
  ]);

  updateBanner(results);
  updateLastChecked();

  setTimeout(() => {
    btn.classList.remove('spinning');
    btn.disabled = false;
    isChecking = false;
  }, 600);
}

// Run on load
runChecks();

// Auto-refresh every 2 minutes, paused when tab is hidden
let autoRefresh = setInterval(() => {
  if (!document.hidden) runChecks();
}, 120000);

document.addEventListener('visibilitychange', () => {
  if (!document.hidden) runChecks();
});
</script>
</body>
</html>
