---
// src/pages/search.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>koels.site — Search</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%2303030a'/%3E%3Ctext x='16' y='26' text-anchor='middle' font-family='Inter%2C system-ui%2C sans-serif' font-size='26' font-weight='900' fill='url(%23g)'%3EK%3C/text%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' stop-color='%23a29bfe'/%3E%3Cstop offset='100%25' stop-color='%236c5ce7'/%3E%3C/linearGradient%3E%3C/defs%3E%3C/svg%3E">
<script is:inline>
  try{ if(localStorage.getItem('search_beta_dismissed')==='1'){ document.documentElement.classList.add('beta-dismissed'); } }catch(e){}
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
<style is:global>
:root {
  --bg:       #03030a;
  --bg2:      #08080f;
  --surface:  #0f0f1a;
  --surface2: #141420;
  --border:   rgba(255,255,255,0.07);
  --border2:  rgba(255,255,255,0.12);
  --text:     #f0eeff;
  --muted:    rgba(240,238,255,0.68);
  --dim:      rgba(240,238,255,0.4);
  --accent:   #6c5ce7;
  --accent2:  #a29bfe;
  --lime:     #00ff88;
  --white:    #ffffff;
  --sans: "Inter", system-ui, sans-serif;
  --mono: "JetBrains Mono", monospace;
  --ease: cubic-bezier(0.16, 1, 0.3, 1);
}
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box }
html { scroll-behavior:smooth; font-size:17px }
body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  min-height:100vh;
  -webkit-font-smoothing: antialiased;
}
a { color:inherit; text-decoration:none }

body::after {
  content:''; position:fixed; inset:0; pointer-events:none; z-index:9990;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
}

/* ── BETA DISCLAIMER MODAL ── */
#beta-overlay {
  position:fixed; inset:0; z-index:9999;
  background:rgba(3,3,10,0.85); backdrop-filter:blur(12px);
  display:flex; align-items:center; justify-content:center;
  padding:20px;
}
html.beta-dismissed #beta-overlay { display:none; }
#beta-modal {
  background:rgba(14,13,28,0.98); border:1px solid rgba(108,92,231,0.35);
  border-radius:16px; padding:32px 28px; max-width:420px; width:100%;
  box-shadow:0 24px 60px rgba(0,0,0,0.6);
}
.beta-modal-icon { font-size:2rem; margin-bottom:14px; }
.beta-modal-title {
  font-size:1rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase;
  color:#f0eeff; margin-bottom:8px;
}
.beta-modal-sub {
  font-size:0.62rem; letter-spacing:0.06em; color:rgba(240,238,255,0.5);
  text-transform:uppercase; margin-bottom:16px;
}
.beta-modal-body {
  font-size:0.66rem; color:rgba(240,238,255,0.55); line-height:1.8;
  margin-bottom:24px;
}
.beta-modal-body b { color:rgba(240,238,255,0.8); }
.beta-modal-footer { display:flex; align-items:center; justify-content:space-between; gap:12px; }
.beta-dismiss-btn {
  flex:1; padding:10px; border-radius:8px; cursor:pointer; font-family:"JetBrains Mono",monospace;
  font-size:0.62rem; letter-spacing:0.1em; text-transform:uppercase; font-weight:700;
  background:rgba(108,92,231,0.25); border:1.5px solid rgba(108,92,231,0.5); color:#a29bfe;
  transition:all 0.18s;
}
.beta-dismiss-btn:hover { background:rgba(108,92,231,0.45); }
.beta-dont-show {
  display:flex; align-items:center; gap:7px; cursor:pointer;
  font-size:0.56rem; color:rgba(240,238,255,0.3); letter-spacing:0.06em;
  white-space:nowrap; user-select:none;
}
.beta-dont-show input { accent-color:#6c5ce7; width:13px; height:13px; cursor:pointer; }
.beta-dont-show:hover { color:rgba(240,238,255,0.55); }

/* Beta badge in header */
.beta-badge {
  font-size:0.48rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase;
  color:#03030a; background:#a29bfe; border-radius:4px;
  padding:2px 7px; align-self:center;
}

/* ── CURTAIN ── */
#curtain {
  position:fixed; inset:0; background:var(--bg); z-index:9997;
  display:flex; align-items:center; justify-content:center;
  transition:opacity 0.8s var(--ease), visibility 0.8s;
}
#curtain.gone { opacity:0; visibility:hidden; pointer-events:none }
.curtain-logo {
  font-family:var(--mono); font-size:0.85rem; letter-spacing:0.25em;
  color:var(--dim); text-transform:uppercase;
  animation:curtain-pulse 1s ease infinite;
}
@keyframes curtain-pulse { 0%,100%{opacity:0.3} 50%{opacity:1} }

/* ── HEADER ── */
header {
  position:fixed; top:0; left:0; right:0; z-index:500;
  height:60px;
  display:flex; align-items:center; justify-content:space-between;
  padding:0 40px;
  border-bottom:1px solid var(--border);
  background:rgba(3,3,10,0.85);
  backdrop-filter:blur(24px) saturate(1.8);
  -webkit-backdrop-filter:blur(24px) saturate(1.8);
}
.logo {
  font-family:var(--mono); font-size:0.7rem; font-weight:700;
  letter-spacing:0.2em; text-transform:uppercase; color:var(--white);
  display:flex; align-items:center; gap:10px;
}
.logo-pulse {
  width:6px; height:6px; border-radius:50%;
  background:var(--lime); box-shadow:0 0 10px var(--lime);
  animation:lg-pulse 2s ease infinite;
}
@keyframes lg-pulse { 0%,100%{box-shadow:0 0 6px var(--lime)} 50%{box-shadow:0 0 20px var(--lime),0 0 40px rgba(0,255,136,0.25)} }

.nav { display:flex; align-items:center; gap:32px }
.nav a {
  font-family:var(--mono); font-size:0.72rem; letter-spacing:0.14em;
  color:var(--muted); text-transform:uppercase; transition:color 0.2s;
}
.nav a:hover { color:var(--white) }

/* ── SEARCH HERO ── */
.search-hero {
  min-height:100vh;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  padding:120px 20px 60px;
  position:relative;
}
.search-hero::before {
  content:''; position:absolute; inset:0;
  background-image:
    linear-gradient(var(--border) 1px, transparent 1px),
    linear-gradient(90deg, var(--border) 1px, transparent 1px);
  background-size:64px 64px;
  mask-image:radial-gradient(ellipse 90% 90% at 50% 40%, black 0%, transparent 100%);
  -webkit-mask-image:radial-gradient(ellipse 90% 90% at 50% 40%, black 0%, transparent 100%);
  opacity:0.5; pointer-events:none; z-index:0;
}
.hero-glow {
  position:absolute; top:40%; left:50%;
  transform:translate(-50%,-50%);
  width:700px; height:700px;
  background:radial-gradient(circle, rgba(108,92,231,0.12) 0%, transparent 60%);
  pointer-events:none; z-index:0;
}
.search-content { position:relative; z-index:2; width:100%; max-width:680px; text-align:center; }

.search-eyebrow {
  display:inline-flex; align-items:center; gap:10px;
  font-family:var(--mono); font-size:0.72rem; font-weight:500;
  letter-spacing:0.2em; text-transform:uppercase; color:var(--accent2);
  margin-bottom:32px;
  animation:fade-up 0.9s var(--ease) both;
}
.search-eyebrow-line { width:28px; height:1px; background:var(--accent) }

h1 {
  font-family:var(--sans);
  font-size:clamp(2.4rem, 5vw, 4.5rem);
  font-weight:900; line-height:0.9;
  letter-spacing:-0.04em; color:var(--white);
  animation:fade-up 0.9s 0.07s var(--ease) both; margin-bottom:12px;
}
h1 .grad {
  background:linear-gradient(135deg, var(--accent2) 0%, #c084fc 50%, var(--accent2) 100%);
  background-size:200% auto;
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  animation:shimmer 4s linear infinite;
}
@keyframes shimmer { to { background-position:200% center } }

.search-desc {
  font-family:var(--mono); font-size:0.78rem; line-height:1.8;
  color:var(--muted); letter-spacing:0.04em; margin-bottom:48px;
  animation:fade-up 0.9s 0.14s var(--ease) both;
}

/* Search input */
.search-box {
  position:relative; width:100%;
  animation:fade-up 0.9s 0.21s var(--ease) both;
}
.search-wrap {
  display:flex; align-items:center; gap:12px;
  background:var(--surface);
  border:1px solid var(--border2);
  border-radius:14px;
  padding:14px 20px;
  transition:border-color 0.25s, box-shadow 0.25s;
}
.search-wrap:focus-within {
  border-color:rgba(108,92,231,0.5);
  box-shadow:0 0 0 3px rgba(108,92,231,0.15), 0 8px 32px rgba(0,0,0,0.3);
}
.search-icon { width:20px; height:20px; flex-shrink:0; fill:var(--dim); }
#search-input {
  flex:1; background:none; border:none; outline:none;
  font-family:var(--mono); font-size:0.85rem; color:var(--text);
  letter-spacing:0.04em;
}
#search-input::placeholder { color:var(--dim); }
#search-btn {
  padding:8px 18px; border-radius:8px; border:none;
  background:var(--accent); color:var(--white);
  font-family:var(--mono); font-size:0.62rem; font-weight:700;
  letter-spacing:0.12em; text-transform:uppercase;
  cursor:pointer; transition:background 0.2s, transform 0.15s;
  white-space:nowrap;
}
#search-btn:hover { background:#5a4bd1; }
#search-btn:active { transform:scale(0.96); }

/* Search type pills */
.search-types {
  display:flex; justify-content:center; gap:8px; margin-top:16px; flex-wrap:wrap;
}
.search-type-btn {
  padding:5px 14px; border-radius:6px;
  border:1px solid var(--border);
  background:transparent;
  font-family:var(--mono); font-size:0.58rem; font-weight:600;
  letter-spacing:0.1em; text-transform:uppercase;
  color:var(--dim); cursor:pointer; transition:all 0.18s;
}
.search-type-btn:hover { color:var(--muted); border-color:var(--border2); background:rgba(255,255,255,0.03); }
.search-type-btn.active { color:var(--accent2); border-color:rgba(108,92,231,0.5); background:rgba(108,92,231,0.12); }

/* ── RESULTS ── */
.results-section {
  width:100%; max-width:680px; margin:0 auto;
  padding:0 20px 80px;
}
.results-header {
  display:flex; align-items:center; justify-content:space-between;
  margin-bottom:20px;
}
.results-count {
  font-family:var(--mono); font-size:0.62rem; letter-spacing:0.12em;
  text-transform:uppercase; color:var(--dim);
}
.results-loading {
  text-align:center; padding:40px 0;
}
.results-loading .spinner {
  width:24px; height:24px; margin:0 auto 12px;
  border:2px solid var(--border2); border-top-color:var(--accent2);
  border-radius:50%; animation:spin 0.8s linear infinite;
}
@keyframes spin { to { transform:rotate(360deg); } }
.results-loading p {
  font-family:var(--mono); font-size:0.68rem; color:var(--dim);
  letter-spacing:0.08em; text-transform:uppercase;
}

/* Result card */
.result-card {
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:12px;
  padding:20px 24px;
  margin-bottom:10px;
  transition:border-color 0.2s, transform 0.18s;
  animation:fade-up 0.4s var(--ease) both;
}
.result-card:hover { border-color:var(--border2); transform:translateY(-1px); }
.result-url {
  font-family:var(--mono); font-size:0.58rem; color:var(--dim);
  letter-spacing:0.06em; margin-bottom:6px;
  overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
}
.result-title {
  font-family:var(--sans); font-size:1.05rem; font-weight:600;
  color:var(--accent2); letter-spacing:-0.01em; margin-bottom:6px;
  line-height:1.4;
}
.result-title:hover { text-decoration:underline; }
.result-snippet {
  font-family:var(--mono); font-size:0.72rem; line-height:1.7;
  color:var(--muted); letter-spacing:0.02em;
}
.result-snippet b { color:var(--text); font-weight:600; }

/* Empty state */
.empty-state {
  text-align:center; padding:60px 20px;
}
.empty-state p {
  font-family:var(--mono); font-size:0.78rem; color:var(--dim);
  letter-spacing:0.06em; line-height:2;
}

/* Footer hint */
.search-footer {
  text-align:center; padding:24px 20px 40px;
  font-family:var(--mono); font-size:0.55rem; color:var(--dim);
  letter-spacing:0.1em; text-transform:uppercase;
}
.search-footer a { color:var(--accent2); }

/* ── UTILS ── */
@keyframes fade-up { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
.reveal { opacity:0; transform:translateY(22px); transition:opacity 0.7s var(--ease), transform 0.7s var(--ease) }
.reveal.visible { opacity:1; transform:translateY(0) }

@media(max-width:860px){
  header { padding:0 20px }
  .nav { display:none }
  .search-hero { padding:120px 16px 40px; min-height:auto; }
  h1 { font-size:2rem; }
  .search-wrap { padding:12px 14px; }
  #search-btn { padding:6px 12px; font-size:0.58rem; }
  .results-section { padding:0 16px 60px; }
}
</style>
</head>
<body>

<!-- BETA DISCLAIMER -->
<div id="beta-overlay">
  <div id="beta-modal">
    <div class="beta-modal-icon">🔍</div>
    <div class="beta-modal-title">Search is in Beta</div>
    <div class="beta-modal-sub">koels.site — Search</div>
    <div class="beta-modal-body">
      This search page is powered by a <b>public SearxNG instance</b>.<br><br>
      It may be rate-limited, slow, or occasionally unavailable. 
      Results come from multiple sources but coverage isn't guaranteed.<br><br>
      You may encounter incomplete results or timeouts.
    </div>
    <div class="beta-modal-footer">
      <button class="beta-dismiss-btn" onclick="acknowledgeSearchBeta()">Got it</button>
      <label class="beta-dont-show">
        <input type="checkbox" id="search-beta-no-show"> Don't show again
      </label>
    </div>
  </div>
</div>

<div id="curtain"><div class="curtain-logo">koels.site</div></div>

<!-- HEADER -->
<header>
  <div class="logo"><div class="logo-pulse"></div>Koels.site</div>
  <nav class="nav">
    <a href="/">Home</a>
    <a href="/links">Links</a>
    <a href="/radar">Radar</a>
  </nav>
  <div style="display:flex;align-items:center;gap:10px;">
    <span class="beta-badge">BETA</span>
  </div>
</header>

<!-- SEARCH HERO -->
<section class="search-hero">
  <div class="hero-glow"></div>
  <div class="search-content">
    <div class="search-eyebrow">
      <span class="search-eyebrow-line"></span>Search
    </div>
    <h1><span class="grad">Search</span> the<br>web.</h1>
    <p class="search-desc">
      Powered by SearxNG — a privacy-respecting metasearch engine.<br>No tracking. No profiling. Just results.
    </p>
    <div class="search-box">
      <div class="search-wrap">
        <svg class="search-icon" viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zM9.5 14A4.5 4.5 0 1 1 14 9.5 4.5 4.5 0 0 1 9.5 14z"/></svg>
        <input type="text" id="search-input" placeholder="Search anything..." autocomplete="off">
        <button id="search-btn">Search</button>
      </div>
      <div class="search-types">
        <button class="search-type-btn active" data-type="general">General</button>
        <button class="search-type-btn" data-type="images">Images</button>
        <button class="search-type-btn" data-type="news">News</button>
        <button class="search-type-btn" data-type="science">Science</button>
      </div>
    </div>
  </div>
</section>

<!-- RESULTS -->
<div class="results-section" id="results-section">
  <div class="empty-state" id="empty-state">
    <p>Type something above and hit search —<br>results will appear here.</p>
  </div>
</div>

<div class="search-footer">
  Powered by <a href="https://github.com/searxng/searxng" target="_blank">SearxNG</a> — results from a public instance. Rate limited.
</div>

<script is:inline>
/* Beta dismiss */
function acknowledgeSearchBeta(){
  const noShow = document.getElementById('search-beta-no-show');
  if(noShow && noShow.checked){
    try{ localStorage.setItem('search_beta_dismissed','1'); }catch(e){}
  }
  document.getElementById('beta-overlay').style.display='none';
}

/* Curtain */
window.addEventListener('load',()=>setTimeout(()=>document.getElementById('curtain').classList.add('gone'),650))

/* Scroll reveal */
const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible')}),{threshold:0.1})
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el))

/* ── SEARCH LOGIC ── */
const input = document.getElementById('search-input');
const btn   = document.getElementById('search-btn');
const resultsSection = document.getElementById('results-section');
const emptyState = document.getElementById('empty-state');

/* ── SearxNG instance ──
   Using a public instance. You can swap this for your own.
   If the instance goes down, pick another from:
   https://searx.space/
*/
const SEARX_URL = 'https://search.bus-hit.me';

let searchType = 'general';

/* Type pills */
document.querySelectorAll('.search-type-btn').forEach(b => {
  b.addEventListener('click', () => {
    document.querySelectorAll('.search-type-btn').forEach(x => x.classList.remove('active'));
    b.classList.add('active');
    searchType = b.dataset.type;
    input.focus();
  });
});

/* Enter key */
input.addEventListener('keydown', e => { if (e.key === 'Enter') doSearch(); });
btn.addEventListener('click', doSearch);

async function doSearch() {
  const q = input.value.trim();
  if (!q) return;

  /* Show loading */
  resultsSection.innerHTML = `
    <div class="results-loading">
      <div class="spinner"></div>
      <p>Searching ${searchType}...</p>
    </div>
  `;

  try {
    const format = searchType === 'images' ? 'json' : 'json';
    const categories = searchType === 'images' ? 'images' : 'general';
    const url = `${SEARX_URL}/search?q=${encodeURIComponent(q)}&format=${format}&categories=${categories}`;

    const resp = await fetch(url, {
      headers: { 'Accept': 'application/json' }
    });

    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
    const data = await resp.json();

    renderResults(data, q);
  } catch (err) {
    resultsSection.innerHTML = `
      <div class="empty-state">
        <p>Search failed — the instance may be busy or rate-limited.<br>
        <span style="color:var(--dim);font-size:0.68rem;">${err.message}</span></p>
      </div>
    `;
  }
}

function renderResults(data, q) {
  const results = data.results || [];

  if (results.length === 0) {
    resultsSection.innerHTML = `
      <div class="empty-state">
        <p>No results for "<strong style="color:var(--text);">${q}</strong>"<br>Try a different query.</p>
      </div>
    `;
    return;
  }

  let html = `
    <div class="results-header">
      <span class="results-count">${results.length} results for "${q}"</span>
    </div>
  `;

  results.forEach((r, i) => {
    html += `
      <a class="result-card" href="${r.url}" target="_blank" rel="noopener" style="animation-delay:${i * 0.05}s">
        <div class="result-url">${r.url || ''}</div>
        <div class="result-title">${r.title || 'Untitled'}</div>
        <div class="result-snippet">${r.content || ''}</div>
      </a>
    `;
  });

  resultsSection.innerHTML = html;
}
</script>
</body>
</html>
